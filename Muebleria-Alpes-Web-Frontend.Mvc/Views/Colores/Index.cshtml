@using Muebleria_Alpes_Web_Frontend.Mvc.ViewModels.Productos
@model List<ColorViewModel>

@{
    ViewData["Title"] = "Colores";
}

<div class="page-header">
    <div class="page-title-box">
        <div class="page-icon">
            <i class="bi bi-palette"></i>
        </div>
        <div>
            <h1>Colores</h1>
            <p>Gestión de colores disponibles</p>
        </div>
    </div>

    <div class="page-actions">
        <input type="text" id="buscarColor" class="form-control search-input" placeholder="Buscar..." />
        <button class="btn btn-primary btn-main" data-bs-toggle="modal" data-bs-target="#modalCrearColor">
            <i class="bi bi-plus-lg"></i> Nuevo Color
        </button>
    </div>
</div>

@if (TempData["Success"] != null)
{
    <div class="alert alert-success">@TempData["Success"]</div>
}

@if (TempData["Error"] != null)
{
    <div class="alert alert-danger">@TempData["Error"]</div>
}

<div class="record-count">
    @Model.Count registros
</div>

<div class="erp-card">
    <div class="table-responsive">
        <table class="table erp-table" id="tablaColores">
            <thead>
                <tr>
                    <th>Código</th>
                    <th>Color</th>
                    <th>Nombre</th>
                    <th>Estado</th>
                    <th class="text-end">Acciones</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var item in Model)
                {
                    <tr>
                        <td>
                            <span class="code-badge">@item.Codigo</span>
                        </td>

                        <td>
                            <div style="display:flex; align-items:center; gap:8px;">
                                <div style="width:28px; height:28px; border-radius:6px; background-color:@(item.HexColor ?? "#ccc"); border:1px solid #ddd;"></div>
                                <span class="code-badge">@(item.HexColor ?? "-")</span>
                            </div>
                        </td>

                        <td>
                            <div class="employee-name">@item.Nombre</div>
                        </td>

                        <td>
                            @if (item.Estado == "ACTIVO")
                            {
                                <span class="status-badge status-active">
                                    <i class="bi bi-check-circle"></i> Activo
                                </span>
                            }
                            else
                            {
                                <span class="status-badge status-inactive">
                                    <i class="bi bi-x-circle"></i> Inactivo
                                </span>
                            }
                        </td>

                        <td class="text-end">
                            <div class="action-group">
                                <button class="btn-icon btn-edit"
                                        type="button"
                                        data-bs-toggle="modal"
                                        data-bs-target="#modalEditarColor-@item.Id"
                                        title="Editar">
                                    <i class="bi bi-pencil"></i>
                                </button>

                                <form asp-controller="Colores"
                                      asp-action="Eliminar"
                                      asp-route-id="@item.Id"
                                      method="post"
                                      class="d-inline"
                                      onsubmit="return confirm('¿Eliminar este color?');">
                                    <button type="submit" class="btn-icon btn-delete" title="Eliminar">
                                        <i class="bi bi-trash"></i>
                                    </button>
                                </form>
                            </div>
                        </td>
                    </tr>

                    @await Html.PartialAsync("_EditarColorModal", item)
                }
            </tbody>
        </table>
    </div>
</div>

@await Html.PartialAsync("_CrearColorModal", new CrearColorViewModel())

@section Scripts {
    <script>
        document.addEventListener('DOMContentLoaded', function () {
            const buscar = document.getElementById('buscarColor');
            if (buscar) {
                buscar.addEventListener('keyup', function () {
                    const val = this.value.toLowerCase();
                    document.querySelectorAll('#tablaColores tbody tr').forEach(row => {
                        row.style.display = row.textContent.toLowerCase().includes(val) ? '' : 'none';
                    });
                });
            }
        });
    </script>
}

@model Muebleria_Alpes_Web_Frontend.Mvc.ViewModels.RecursosHumanos.EmpleadoViewModel

<div class="modal fade" id="modalEditarEmpleado-@Model.Id" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-md modal-dialog-centered">
        <div class="modal-content erp-modal">
            <form asp-controller="Empleados" asp-action="Actualizar" asp-route-id="@Model.Id" method="post">
                <div class="modal-header">
                    <h5 class="modal-title">Editar Empleado</h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
                </div>

                <div class="modal-body">
                    <div class="employee-mini-card">
                        <div class="avatar-soft">
                            <i class="bi bi-person"></i>
                        </div>
                        <div>
                            <strong>@Model.NombreCompleto</strong>
                            <small>@Model.Codigo</small>
                        </div>
                    </div>

                    <div class="mb-3">
                        <label class="form-label">Email *</label>
                        <input name="Email" type="email" class="form-control" value="@Model.Email" required />
                    </div>

                    <div class="mb-3">
                        <label class="form-label">Teléfono *</label>
                        <input name="Telefono" class="form-control" value="@Model.Telefono" required />
                    </div>

                    <div class="alert alert-light border">
                        Por ahora tu backend solo permite actualizar <strong>Email</strong> y <strong>Teléfono</strong> por PUT.
                    </div>
                </div>

                <div class="modal-footer">
                    <button type="button" class="btn btn-light" data-bs-dismiss="modal">
                        Cancelar
                    </button>
                    <button type="submit" class="btn btn-primary btn-main">
                        <i class="bi bi-save"></i> Guardar cambios
                    </button>
                </div>
            </form>
        </div>
    </div>
</div>
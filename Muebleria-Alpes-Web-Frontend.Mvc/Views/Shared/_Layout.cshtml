<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Los Alpes</title>

    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/admin-layout.css" asp-append-version="true" />
</head>
<body>
    <div class="admin-wrapper">
        <aside class="sidebar" id="sidebar">
            <div class="sidebar-header">
                <div class="brand-icon">
                    <i class="bi bi-triangle"></i>
                </div>
                <div>
                    <div class="brand-title">Los Alpes</div>
                    <div class="brand-subtitle">SISTEMA ERP</div>
                </div>
            </div>

            <div class="menu-title">MENÚ PRINCIPAL</div>

            <nav class="sidebar-menu">
                <a class="menu-item" asp-controller="Home" asp-action="Index">
                    <span class="menu-left">
                        <i class="bi bi-grid"></i>
                        <span>Dashboard</span>
                    </span>
                </a>

                <div class="menu-group">
                    <button class="menu-item menu-toggle" type="button" data-bs-toggle="collapse" data-bs-target="#productosMenu">
                        <span class="menu-left">
                            <i class="bi bi-box"></i>
                            <span>Productos</span>
                        </span>
                        <i class="bi bi-chevron-down small-arrow"></i>
                    </button>
                    <div class="collapse show submenu" id="productosMenu">
                        <a asp-controller="Productos" asp-action="Index"><i class="bi bi-box"></i> Catálogo</a>
                        <a asp-controller="Categorias" asp-action="Index"><i class="bi bi-tag"></i> Categorías</a>
                        <a asp-controller="Colores" asp-action="Index"><i class="bi bi-palette"></i> Colores</a>
                        <a asp-controller="Materiales" asp-action="Index"><i class="bi bi-layers"></i> Materiales</a>
                        <a asp-controller="Promociones" asp-action="Index"><i class="bi bi-ticket-perforated"></i> Promociones</a>
                    </div>
                </div>

                <a class="menu-item" asp-controller="Clientes" asp-action="Index">
                    <span class="menu-left">
                        <i class="bi bi-people"></i>
                        <span>Clientes</span>
                    </span>
                </a>

                <div class="menu-group">
                    <button class="menu-item menu-toggle" type="button" data-bs-toggle="collapse" data-bs-target="#ventasMenu">
                        <span class="menu-left">
                            <i class="bi bi-cart"></i>
                            <span>Ventas</span>
                        </span>
                        <i class="bi bi-chevron-down small-arrow"></i>
                    </button>
                    <div class="collapse show submenu" id="ventasMenu">
                        <a asp-controller="Ventas" asp-action="Index"><i class="bi bi-cart"></i> Órdenes</a>
                        <a asp-controller="Facturas" asp-action="Index"><i class="bi bi-file-earmark-text"></i> Facturas</a>
                        <a asp-controller="Pagos" asp-action="Index"><i class="bi bi-credit-card"></i> Pagos</a>
                    </div>
                </div>

                <div class="menu-group">
                    <button class="menu-item menu-toggle" type="button" data-bs-toggle="collapse" data-bs-target="#inventarioMenu">
                        <span class="menu-left">
                            <i class="bi bi-building"></i>
                            <span>Inventario</span>
                        </span>
                        <i class="bi bi-chevron-down small-arrow"></i>
                    </button>
                    <div class="collapse show submenu" id="inventarioMenu">
                        <a asp-controller="Inventario" asp-action="Index"><i class="bi bi-box"></i> Existencias</a>
                        <a asp-controller="Bodegas" asp-action="Index"><i class="bi bi-buildings"></i> Bodegas</a>
                        <a asp-controller="MovimientosInventario" asp-action="Index"><i class="bi bi-arrow-left-right"></i> Movimientos</a>
                    </div>
                </div>

                <a class="menu-item" asp-controller="Produccion" asp-action="Index">
                    <span class="menu-left">
                        <i class="bi bi-building-gear"></i>
                        <span>Producción</span>
                    </span>
                </a>

                <div class="menu-group">
                    <button class="menu-item menu-toggle menu-active-accent" type="button" data-bs-toggle="collapse" data-bs-target="#rrhhMenu">
                        <span class="menu-left">
                            <i class="bi bi-person-gear"></i>
                            <span>RRHH</span>
                        </span>
                        <i class="bi bi-chevron-down small-arrow"></i>
                    </button>
                    <div class="collapse show submenu" id="rrhhMenu">
                        <a asp-controller="Empleados" asp-action="Index"><i class="bi bi-person"></i> Empleados</a>
                        <a asp-controller="Contratos" asp-action="Index"><i class="bi bi-file-earmark-check"></i> Contratos</a>
                        <a class="submenu-active" asp-controller="Nomina" asp-action="Index"><i class="bi bi-currency-dollar"></i> Nómina</a>
                        <a asp-controller="Asistencias" asp-action="Index"><i class="bi bi-clock-history"></i> Asistencias</a>
                    </div>
                </div>
            </nav>

            <div class="store-box">
                <a href="#">
                    <i class="bi bi-shop"></i>
                    <span>Ver tienda virtual</span>
                </a>
            </div>

            <div class="user-box">
                <div class="user-avatar">AD</div>
                <div>
                    <div class="user-name">Admin</div>
                    <div class="user-email">admin@losalpes.com</div>
                </div>
            </div>
        </aside>

        <div class="content-area">
            <header class="topbar">
                <div class="topbar-search">
                    <i class="bi bi-search"></i>
                    <input type="text" placeholder="Buscar en el sistema..." />
                </div>

                <div class="topbar-actions">
                    <button type="button" class="topbar-btn">
                        <i class="bi bi-bell"></i>
                    </button>
                    <button type="button" class="topbar-btn">
                        <i class="bi bi-moon"></i>
                    </button>
                </div>
            </header>

            <main class="main-content">
                @RenderBody()
            </main>
        </div>
    </div>

    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
@using Microsoft.Extensions.Configuration
@inject IConfiguration Configuration
@{
    var currentController = ViewContext.RouteData.Values["controller"]?.ToString() ?? "";
    var currentAction = ViewContext.RouteData.Values["action"]?.ToString() ?? "";

    bool IsController(params string[] controllers)
    {
        return controllers.Any(c => string.Equals(c, currentController, StringComparison.OrdinalIgnoreCase));
    }

    string ActiveMenu(params string[] controllers)
    {
        return IsController(controllers) ? "menu-active-accent" : "";
    }

    string ActiveSubmenu(string controller, string action)
    {
        return string.Equals(currentController, controller, StringComparison.OrdinalIgnoreCase) && 
               string.Equals(currentAction, action, StringComparison.OrdinalIgnoreCase)
            ? "submenu-active"
            : "";
    }

    string ShowMenu(params string[] controllers)
    {
        return IsController(controllers) ? "show" : "";
    }
}

<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />

    <title>@ViewData["Title"] - Los Alpes ERP</title>

    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/admin-layout.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/modulos.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/crud.css" />
    <style>
        /* Global Loading Overlay */
        #global-loader {
            position: fixed;
            top: 0; left: 0;
            width: 100%; height: 100%;
            background: rgba(255, 255, 255, 0.7);
            z-index: 9999;
            display: none;
            justify-content: center;
            align-items: center;
            flex-direction: column;
            backdrop-filter: blur(2px);
        }
        .spinner-erp { width: 3rem; height: 3rem; color: #1f1f24; }
    </style>

    <script>
        // Configuración Global ERP Inyectada desde el servidor
        window.erpConfig = {
            apiBaseUrl: '@Configuration["ApiSettings:BaseUrl"]api'
        };
    </script>

    @await RenderSectionAsync("Styles", required: false)
</head>

<body>
    <div class="admin-wrapper">

        <div class="sidebar-overlay" id="sidebarOverlay"></div>

        <aside class="sidebar" id="adminSidebar">
            <div class="sidebar-header">
                <a class="brand-link" asp-controller="Home" asp-action="Index">
                    <div class="brand-icon">
                        <i class="bi bi-triangle"></i>
                    </div>
                    <div>
                        <div class="brand-title">Los Alpes</div>
                        <div class="brand-subtitle">SISTEMA ERP</div>
                    </div>
                </a>
            </div>

            <div class="menu-title">MENÚ PRINCIPAL</div>

            <nav class="sidebar-menu">

                <a class="menu-item @ActiveMenu("Home")" asp-controller="Home" asp-action="Index">
                    <span class="menu-left">
                        <i class="bi bi-grid"></i>
                        <span>Dashboard</span>
                    </span>
                </a>

                <div class="menu-group">
                    <button class="menu-item menu-toggle @ActiveMenu("Productos", "Categorias", "Colores", "Materiales", "Promociones")"
                            type="button"
                            data-bs-toggle="collapse"
                            data-bs-target="#productosMenu"
                            aria-expanded="@(IsController("Productos", "Categorias", "Colores", "Materiales", "Promociones").ToString().ToLower())">
                        <span class="menu-left">
                            <i class="bi bi-box-seam"></i>
                            <span>Productos</span>
                        </span>
                        <i class="bi bi-chevron-down small-arrow"></i>
                    </button>

                    <div class="collapse submenu @ShowMenu("Productos", "Categorias", "Colores", "Materiales", "Promociones")" id="productosMenu">
                        <a class="@ActiveSubmenu("Productos", "Index")" asp-controller="Productos" asp-action="Index">
                            <i class="bi bi-box"></i> Catálogo
                        </a>
                        <a class="@ActiveSubmenu("Categorias", "Index")" asp-controller="Categorias" asp-action="Index">
                            <i class="bi bi-tag"></i> Categorías
                        </a>
                        <a class="@ActiveSubmenu("Colores", "Index")" asp-controller="Colores" asp-action="Index">
                            <i class="bi bi-palette"></i> Colores
                        </a>
                        <a class="@ActiveSubmenu("Materiales", "Index")" asp-controller="Materiales" asp-action="Index">
                            <i class="bi bi-layers"></i> Materiales
                        </a>
                        <a class="@ActiveSubmenu("Promociones", "Index")" asp-controller="Promociones" asp-action="Index">
                            <i class="bi bi-ticket-perforated"></i> Promociones
                        </a>
                    </div>
                </div>

                <a class="menu-item @ActiveMenu("Clientes")" asp-controller="Clientes" asp-action="Index">
                    <span class="menu-left">
                        <i class="bi bi-people"></i>
                        <span>Clientes</span>
                    </span>
                </a>



                <div class="menu-group">
                    <button class="menu-item menu-toggle @ActiveMenu("Seguridad")"
                            type="button"
                            data-bs-toggle="collapse"
                            data-bs-target="#seguridadMenu"
                            aria-expanded="@(IsController("Seguridad").ToString().ToLower())">
                        <span class="menu-left">
                            <i class="bi bi-shield-lock"></i>
                            <span>Seguridad</span>
                        </span>
                        <i class="bi bi-chevron-down small-arrow"></i>
                    </button>

                    <div class="collapse submenu @ShowMenu("Seguridad")" id="seguridadMenu">
                        <a asp-controller="Seguridad" asp-action="Usuarios">
                            <i class="bi bi-people"></i> Usuarios
                        </a>
                        <a asp-controller="Seguridad" asp-action="Roles">
                            <i class="bi bi-person-badge"></i> Roles
                        </a>
                        <a asp-controller="Seguridad" asp-action="Permisos">
                            <i class="bi bi-key"></i> Permisos
                        </a>
                        <a asp-controller="Seguridad" asp-action="Asignaciones">
                            <i class="bi bi-diagram-3"></i> Asignaciones
                        </a>
                        <a asp-controller="Seguridad" asp-action="Bitacora">
                            <i class="bi bi-journal-text"></i> Bitácora
                        </a>
                    </div>
                </div>

                <a class="menu-item @ActiveMenu("Envios")" asp-controller="Envios" asp-action="Index">
                    <span class="menu-left">
                        <i class="bi bi-truck"></i>
                        <span>Envíos</span>
                    </span>
                </a>

                <div class="menu-group">
                    <button class="menu-item menu-toggle @ActiveMenu("Reportes")"
                            type="button"
                            data-bs-toggle="collapse"
                            data-bs-target="#reportesMenu"
                            aria-expanded="@(IsController("Reportes").ToString().ToLower())">
                        <span class="menu-left">
                            <i class="bi bi-bar-chart-line"></i>
                            <span>Reportes</span>
                        </span>
                        <i class="bi bi-chevron-down small-arrow"></i>
                    </button>
                    <div class="collapse submenu @ShowMenu("Reportes")" id="reportesMenu">
                        <a asp-controller="Reportes" asp-action="Index"><i class="bi bi-grid"></i> Panel</a>
                        <a asp-controller="Reportes" asp-action="Cliente"><i class="bi bi-person-lines-fill"></i> Clientes</a>
                        <a asp-controller="Reportes" asp-action="Ventas"><i class="bi bi-graph-up-arrow"></i> Ventas</a>
                        <a asp-controller="Reportes" asp-action="Caja"><i class="bi bi-cash-stack"></i> Caja</a>
                        <a asp-controller="Reportes" asp-action="Marketing"><i class="bi bi-megaphone"></i> Marketing</a>
                    </div>
                </div>

                <div class="menu-group">
                    <button class="menu-item menu-toggle @ActiveMenu("Ventas", "Facturas", "Pagos")"
                            type="button"
                            data-bs-toggle="collapse"
                            data-bs-target="#ventasMenu"
                            aria-expanded="@(IsController("Ventas", "Facturas", "Pagos").ToString().ToLower())">
                        <span class="menu-left">
                            <i class="bi bi-cart"></i>
                            <span>Ventas</span>
                        </span>
                        <i class="bi bi-chevron-down small-arrow"></i>
                    </button>

                    <div class="collapse submenu @ShowMenu("Ventas", "Facturas", "Pagos")" id="ventasMenu">
                        <a class="@ActiveSubmenu("Ventas", "Index")" asp-controller="Ventas" asp-action="Index">
                            <i class="bi bi-cart"></i> Órdenes
                        </a>
                        <a class="@ActiveSubmenu("Facturas", "Index")" asp-controller="Facturas" asp-action="Index">
                            <i class="bi bi-file-earmark-text"></i> Facturas
                        </a>
                        <a class="@ActiveSubmenu("Pagos", "Index")" asp-controller="Pagos" asp-action="Index">
                            <i class="bi bi-credit-card"></i> Pagos
                        </a>
                        <a asp-controller="Devoluciones" asp-action="Index"><i class="bi bi-arrow-return-left"></i> Devoluciones</a>
                    </div>
                </div>

                <div class="menu-group">
                    <button class="menu-item menu-toggle @ActiveMenu("Finanzas")"
                            type="button"
                            data-bs-toggle="collapse"
                            data-bs-target="#finanzasMenu"
                            aria-expanded="@(IsController("Finanzas").ToString().ToLower())">
                        <span class="menu-left">
                            <i class="bi bi-bank"></i>
                            <span>Finanzas</span>
                        </span>
                        <i class="bi bi-chevron-down small-arrow"></i>
                    </button>

                    <div class="collapse submenu @ShowMenu("Finanzas")" id="finanzasMenu">
                        <a class="@ActiveSubmenu("Finanzas", "Historial")" asp-controller="Finanzas" asp-action="Historial">
                            <i class="bi bi-journal-text"></i> Kárdex Financiero
                        </a>
                    </div>
                </div>

                <div class="menu-group">
                    <button class="menu-item menu-toggle @ActiveMenu("Inventario", "Bodegas", "MovimientosInventario")"
                            type="button"
                            data-bs-toggle="collapse"
                            data-bs-target="#inventarioMenu"
                            aria-expanded="@(IsController("Inventario", "Bodegas", "MovimientosInventario").ToString().ToLower())">
                        <span class="menu-left">
                            <i class="bi bi-building"></i>
                            <span>Inventario</span>
                        </span>
                        <i class="bi bi-chevron-down small-arrow"></i>
                    </button>

                    <div class="collapse submenu @ShowMenu("Inventario")" id="inventarioMenu">
                        <a class="@ActiveSubmenu("Inventario", "Index")" asp-controller="Inventario" asp-action="Index">
                            <i class="bi bi-box"></i> Existencias
                        </a>
                        <a class="@ActiveSubmenu("Inventario", "Bodegas")" asp-controller="Inventario" asp-action="Bodegas">
                            <i class="bi bi-buildings"></i> Bodegas
                        </a>
                        <a class="@ActiveSubmenu("Inventario", "Movimientos")" asp-controller="Inventario" asp-action="Movimientos">
                            <i class="bi bi-arrow-left-right"></i> Movimientos
                        </a>
                    </div>
                </div>

                <a class="menu-item @ActiveMenu("Produccion")" asp-controller="Produccion" asp-action="Index">
                    <span class="menu-left">
                        <i class="bi bi-building-gear"></i>
                        <span>Producción</span>
                    </span>
                </a>

                <div class="menu-group">
                    <button class="menu-item menu-toggle @ActiveMenu("Empleados", "Contratos", "Nomina", "Asistencias", "Vacaciones", "Puestos", "Departamentos", "Evaluaciones", "Turnos")"
                            type="button"
                            data-bs-toggle="collapse"
                            data-bs-target="#rrhhMenu"
                            aria-expanded="@(IsController("Empleados", "Contratos", "Nomina", "Asistencias", "Vacaciones", "Puestos", "Departamentos", "Evaluaciones", "Turnos").ToString().ToLower())">
                        <span class="menu-left">
                            <i class="bi bi-person-gear"></i>
                            <span>RRHH</span>
                        </span>
                        <i class="bi bi-chevron-down small-arrow"></i>
                    </button>

                    <div class="collapse submenu @ShowMenu("Empleados", "Contratos", "Nomina", "Asistencias", "Vacaciones", "Puestos", "Departamentos", "Evaluaciones", "Turnos")" id="rrhhMenu">
                        <a class="@ActiveSubmenu("Empleados", "Index")" asp-controller="Empleados" asp-action="Index">
                            <i class="bi bi-person"></i> Empleados
                        </a>
                        <a class="@ActiveSubmenu("Contratos", "Index")" asp-controller="Contratos" asp-action="Index">
                            <i class="bi bi-file-earmark-check"></i> Contratos
                        </a>
                        <a class="@ActiveSubmenu("Nomina", "Index")" asp-controller="Nomina" asp-action="Index">
                            <i class="bi bi-currency-dollar"></i> Nómina
                        </a>
                        <a class="@ActiveSubmenu("Asistencias", "Index")" asp-controller="Asistencias" asp-action="Index">
                            <i class="bi bi-clock-history"></i> Asistencias
                        </a>
                        <a class="@ActiveSubmenu("Vacaciones", "Index")" asp-controller="Vacaciones" asp-action="Index">
                            <i class="bi bi-airplane"></i> Vacaciones
                        </a>
                        <a class="@ActiveSubmenu("Puestos", "Index")" asp-controller="Puestos" asp-action="Index">
                            <i class="bi bi-briefcase"></i> Puestos
                        </a>
                        <a class="@ActiveSubmenu("Departamentos", "Index")" asp-controller="Departamentos" asp-action="Index">
                            <i class="bi bi-diagram-3"></i> Departamentos
                        </a>
                        <a class="@ActiveSubmenu("Evaluaciones", "Index")" asp-controller="Evaluaciones" asp-action="Index">
                            <i class="bi bi-clipboard-check"></i> Evaluaciones
                        </a>
                        <a class="@ActiveSubmenu("Turnos", "Index")" asp-controller="Turnos" asp-action="Index">
                            <i class="bi bi-calendar2-week"></i> Turnos
                        </a>
                    </div>
                </div>

            </nav>

            <div class="store-box">
                <a asp-controller="Tienda" asp-action="Index">
                    <i class="bi bi-shop"></i>
                    <span>Ver tienda virtual</span>
                </a>
            </div>

            <div class="user-box">
                @if (User.Identity?.IsAuthenticated == true)
                {
                    var nombreCompleto = User.FindFirst(System.Security.Claims.ClaimTypes.GivenName)?.Value ?? "Usuario";
                    var rol = User.FindFirst(System.Security.Claims.ClaimTypes.Role)?.Value ?? "";
                    var initials = string.Concat(nombreCompleto.Split(' ').Take(2).Select(p => p.FirstOrDefault()));
                    <div class="user-avatar">@initials.ToUpper()</div>
                    <div>
                        <div class="user-name">@nombreCompleto</div>
                        <div class="user-email">@rol</div>
                    </div>
                }
                else
                {
                    <div class="user-avatar"><i class="bi bi-person"></i></div>
                    <div>
                        <div class="user-name">Invitado</div>
                        <div class="user-email"><a href="/Login/Login" class="text-white-50">Iniciar sesión</a></div>
                    </div>
                }
            </div>
        </aside>

        <div class="content-area">
            <header class="topbar">
                <div class="topbar-left">
                    <button type="button" class="sidebar-toggle" id="toggleSidebar">
                        <i class="bi bi-list"></i>
                    </button>

                    <div class="topbar-search">
                        <i class="bi bi-search"></i>
                        <input type="text" placeholder="Buscar en el sistema..." />
                    </div>
                </div>
                <div class="topbar-actions">
                    @* Botón Ver Tienda — accesible para todos los no-clientes en el admin *@
                    <a asp-controller="Tienda" asp-action="Index"
                       class="topbar-btn" title="Ver Tienda Virtual">
                        <i class="bi bi-shop"></i>
                    </a>
                    @if (User.Identity?.IsAuthenticated == true)
                    {
                        <a asp-controller="Login" asp-action="Logout" class="topbar-btn" title="Cerrar sesión">
                            <i class="bi bi-box-arrow-right"></i>
                        </a>
                    }
                    else
                    {
                        <a asp-controller="Login" asp-action="Login" class="topbar-btn" title="Iniciar sesión">
                            <i class="bi bi-box-arrow-in-right"></i>
                        </a>
                    }
                </div>
            </header>

            <main class="main-content">
                @RenderBody()
            </main>
        </div>
    </div>

    <!-- Global Elements -->
    <div id="global-loader">
        <div class="spinner-border spinner-erp" role="status"></div>
        <div class="mt-3 fw-bold text-dark text-uppercase small" style="letter-spacing: 1px;">Procesando transacción ERP...</div>
    </div>

    <div class="toast-container position-fixed bottom-0 end-0 p-3" id="toastPlacement">
        <div id="erpToast" class="toast align-items-center text-white border-0" role="alert" aria-live="assertive" aria-atomic="true" style="border-radius: 12px;">
            <div class="d-flex">
                <div class="toast-body">
                    <i id="erpToastIcon" class="bi me-2"></i>
                    <span id="erpToastMessage"></span>
                </div>
                <button type="button" class="btn-close btn-close-white me-2 m-auto" data-bs-dismiss="toast"></button>
            </div>
        </div>
    </div>

    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/admin-layout.js" asp-append-version="true"></script>
    <script src="~/js/erp-helpers.js" asp-append-version="true"></script>
    <script src="~/js/erp-validation.js" asp-append-version="true"></script>

    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>

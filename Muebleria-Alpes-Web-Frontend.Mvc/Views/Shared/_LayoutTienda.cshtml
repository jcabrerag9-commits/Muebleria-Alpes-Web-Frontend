<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />

    <title>@ViewData["Title"] - Mueblería Los Alpes</title>

    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" />
    <link rel="stylesheet" href="~/css/tienda.css" asp-append-version="true" />

    <!-- PWA -->
    <link rel="manifest" href="/manifest.json" />
    <meta name="theme-color" content="#4a1822" />
    <meta name="mobile-web-app-capable" content="yes" />
    <meta name="apple-mobile-web-app-capable" content="yes" />
    <meta name="apple-mobile-web-app-status-bar-style" content="black-translucent" />

    @await RenderSectionAsync("Styles", required: false)
</head>

<body>

    <!-- Navbar -->
    <nav class="navbar navbar-expand-lg tienda-navbar">

        <div class="container">

            <a class="navbar-brand tienda-brand"
               asp-controller="Tienda"
               asp-action="Index">

                <i class="bi bi-triangle-fill"></i> Los Alpes
            </a>

            <button class="navbar-toggler"
                    type="button"
                    data-bs-toggle="collapse"
                    data-bs-target="#navbarMain"
                    aria-controls="navbarMain"
                    aria-expanded="false"
                    aria-label="Toggle navigation">

                <span class="navbar-toggler-icon"></span>
            </button>

            <div class="collapse navbar-collapse" id="navbarMain">

                <ul class="navbar-nav me-auto">

                    <li class="nav-item">
                        <a class="nav-link"
                           asp-controller="Tienda"
                           asp-action="Index"
                           data-i18n="nav.home">

                            Inicio
                        </a>
                    </li>

                    <li class="nav-item">
                        <a class="nav-link"
                           asp-controller="Tienda"
                           asp-action="Catalogo"
                           data-i18n="nav.catalog">

                            Catálogo
                        </a>
                    </li>

                    <li class="nav-item">
                        <a class="nav-link"
                           asp-controller="Tienda"
                           asp-action="Ofertas"
                           data-i18n="nav.offers">

                            Ofertas
                        </a>
                    </li>

                </ul>

                <div class="d-flex align-items-center gap-3">

                    <!-- BOTON INSTALAR -->
                    <button id="btnInstalarApp"
                            type="button"
                            class="btn btn-sm btn-tienda-outline"
                            style="display:inline-flex;">

                        <i class="bi bi-phone"></i>
                        Instalar App
                    </button>

                    <!-- LANGUAGE -->
                    <div class="d-flex align-items-center gap-1">

                        <button type="button"
                                class="btn btn-sm lang-btn lang-active"
                                data-lang-btn="es"
                                onclick="i18n.load('es')"
                                title="Español">

                            ES
                        </button>

                        <span class="text-white-50"
                              style="font-size:0.7rem;">

                            |
                        </span>

                        <button type="button"
                                class="btn btn-sm lang-btn"
                                data-lang-btn="en"
                                onclick="i18n.load('en')"
                                title="English">

                            EN
                        </button>
                    </div>

                    <!-- CARRITO -->
                    <a asp-controller="Carrito"
                       asp-action="Index"
                       class="btn-carrito"
                       data-i18n-title="nav.cart_title">

                        <i class="bi bi-cart3"></i>

                        <span class="carrito-badge"
                              id="cartCount">

                            0
                        </span>
                    </a>

                    @if (User.Identity?.IsAuthenticated == true)
                    {
                        var nombre = User.FindFirst(System.Security.Claims.ClaimTypes.GivenName)?.Value ?? "Usuario";

                        var rol = User.FindFirst(System.Security.Claims.ClaimTypes.Role)?.Value ?? string.Empty;

                        var esCliente = rol.Equals("Cliente", StringComparison.OrdinalIgnoreCase);

                        <span class="text-white-50 small">

                            <span data-i18n="nav.hello">
                                Hola,
                            </span>

                            @nombre
                        </span>

                        @if (esCliente)
                        {
                            <div class="dropdown">

                                <button class="btn btn-sm btn-tienda-outline dropdown-toggle"
                                        type="button"
                                        data-bs-toggle="dropdown"
                                        aria-expanded="false">

                                    <i class="bi bi-person-circle"></i>

                                    <span data-i18n="nav.my_account">
                                        Mi cuenta
                                    </span>
                                </button>

                                <ul class="dropdown-menu dropdown-menu-end shadow border-0"
                                    style="border-radius:12px; min-width:200px;">

                                    <li>
                                        <a class="dropdown-item py-2"
                                           asp-controller="Cuenta"
                                           asp-action="MisPedidos">

                                            <i class="bi bi-bag-check me-2"
                                               style="color:var(--tienda-primary);"></i>

                                            <span data-i18n="nav.my_orders">
                                                Mis Pedidos
                                            </span>
                                        </a>
                                    </li>

                                    <li>
                                        <a class="dropdown-item py-2"
                                           asp-controller="Cuenta"
                                           asp-action="MisDirecciones">

                                            <i class="bi bi-geo-alt me-2"
                                               style="color:var(--tienda-primary);"></i>

                                            <span data-i18n="nav.my_addresses">
                                                Mis Direcciones
                                            </span>
                                        </a>
                                    </li>

                                    <li>
                                        <hr class="dropdown-divider my-1">
                                    </li>

                                    <li>
                                        <a class="dropdown-item py-2 text-danger"
                                           asp-controller="Login"
                                           asp-action="Logout">

                                            <i class="bi bi-box-arrow-right me-2"></i>

                                            <span data-i18n="nav.logout">
                                                Cerrar sesión
                                            </span>
                                        </a>
                                    </li>

                                </ul>
                            </div>
                        }
                        else
                        {
                            <a asp-controller="Home"
                               asp-action="Index"
                               class="btn btn-sm btn-tienda-outline"
                               title="Panel de administración">

                                <i class="bi bi-speedometer2"></i>

                                <span data-i18n="nav.admin">
                                    Admin
                                </span>
                            </a>

                            <a asp-controller="Login"
                               asp-action="Logout"
                               class="btn btn-sm btn-tienda-outline">

                                <i class="bi bi-box-arrow-right"></i>

                                <span data-i18n="nav.signout">
                                    Salir
                                </span>
                            </a>
                        }
                    }
                    else
                    {
                        <a asp-controller="Login"
                           asp-action="Login"
                           class="btn btn-sm btn-tienda-outline">

                            <i class="bi bi-box-arrow-in-right"></i>

                            <span data-i18n="nav.signin">
                                Iniciar sesión
                            </span>
                        </a>
                    }

                </div>
            </div>
        </div>
    </nav>

    <!-- TOASTS -->
    @if (TempData["Success"] is string msgOk)
    {
        <div class="toast-container position-fixed top-0 end-0 p-3"
             style="z-index:9999;">

            <div class="toast show align-items-center text-bg-success border-0"
                 role="alert">

                <div class="d-flex">

                    <div class="toast-body">
                        <i class="bi bi-check-circle-fill me-2"></i>
                        @msgOk
                    </div>

                    <button type="button"
                            class="btn-close btn-close-white me-2 m-auto"
                            data-bs-dismiss="toast">
                    </button>

                </div>
            </div>
        </div>
    }

    @if (TempData["Error"] is string msgErr)
    {
        <div class="toast-container position-fixed top-0 end-0 p-3"
             style="z-index:9999;">

            <div class="toast show align-items-center text-bg-danger border-0"
                 role="alert">

                <div class="d-flex">

                    <div class="toast-body">
                        <i class="bi bi-exclamation-triangle-fill me-2"></i>
                        @msgErr
                    </div>

                    <button type="button"
                            class="btn-close btn-close-white me-2 m-auto"
                            data-bs-dismiss="toast">
                    </button>

                </div>
            </div>
        </div>
    }

    <main>
        @RenderBody()
    </main>

    <!-- FOOTER -->
    <footer class="tienda-footer">

        <div class="container">

            <div class="row">

                <div class="col-md-4 mb-4">

                    <h5>
                        <i class="bi bi-triangle-fill"></i>
                        Mueblería Los Alpes
                    </h5>

                    <p class="text-muted"
                       data-i18n="footer.tagline">

                        Tu hogar, nuestra pasión.
                        Muebles de calidad con garantía.
                    </p>
                </div>

                <div class="col-md-4 mb-4">

                    <h6 data-i18n="footer.customer_service">
                        Atención al cliente
                    </h6>

                    <ul class="list-unstyled text-muted">

                        <li>
                            <i class="bi bi-telephone me-2"></i>
                            +502 0000-0000
                        </li>

                        <li>
                            <i class="bi bi-envelope me-2"></i>
                            info@losalpes.com
                        </li>

                        <li>
                            <i class="bi bi-clock me-2"></i>

                            <span data-i18n="footer.schedule">
                                Lun-Vie 8:00-18:00
                            </span>
                        </li>

                    </ul>
                </div>

                <div class="col-md-4 mb-4">

                    <h6 data-i18n="footer.information">
                        Información
                    </h6>

                    <ul class="list-unstyled">

                        <li>
                            <a href="#"
                               class="text-muted"
                               data-i18n="footer.return_policy">

                                Política de devoluciones
                            </a>
                        </li>

                        <li>
                            <a href="#"
                               class="text-muted"
                               data-i18n="footer.warranties">

                                Garantías
                            </a>
                        </li>

                        <li>
                            <a href="#"
                               class="text-muted"
                               data-i18n="footer.shipping">

                                Envíos
                            </a>
                        </li>

                    </ul>
                </div>
            </div>

            <hr />

            <p class="text-center text-muted mb-0"
               data-i18n="footer.rights">

                © 2026 Mueblería Los Alpes.
                Todos los derechos reservados.
            </p>
        </div>
    </footer>

    <!-- SCRIPTS -->
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>

    <script src="~/js/tienda.js"
            asp-append-version="true"></script>

    <script src="~/js/i18n.js"
            asp-append-version="true"></script>

    <!-- PWA -->
    <script>

        let deferredPrompt = null;

        const btnInstalar =
            document.getElementById(
                "btnInstalarApp"
            );

        // REGISTRAR SERVICE WORKER
        if ("serviceWorker" in navigator) {

            window.addEventListener(
                "load",
                () => {

                    navigator.serviceWorker
                        .register("/service-worker.js")
                        .then(reg => {

                            console.log(
                                "Service Worker registrado:",
                                reg.scope
                            );
                        })
                        .catch(error => {

                            console.error(
                                "Error Service Worker:",
                                error
                            );
                        });
                });
        }

        // EVENTO PWA
        window.addEventListener(
            "beforeinstallprompt",
            (e) => {

                console.log(
                    "beforeinstallprompt disponible"
                );

                e.preventDefault();

                deferredPrompt = e;
            });

        // CLICK BOTON
        if (btnInstalar) {

            btnInstalar.addEventListener(
                "click",
                async () => {

                    // ANDROID / CHROME
                    if (deferredPrompt) {

                        deferredPrompt.prompt();

                        const { outcome } =
                            await deferredPrompt.userChoice;

                        console.log(
                            "Resultado instalación:",
                            outcome
                        );

                        deferredPrompt = null;

                        return;
                    }

                    // FALLBACK
                    alert(
                        "Para instalar la app:\n\n" +
                        "Android Chrome:\n" +
                        "Menú ⋮ > Instalar aplicación\n\n" +
                        "iPhone Safari:\n" +
                        "Compartir > Añadir a pantalla de inicio"
                    );
                });
        }

        // APP INSTALADA
        window.addEventListener(
            "appinstalled",
            () => {

                console.log(
                    "PWA instalada correctamente"
                );
            });

    </script>

    @await RenderSectionAsync("Scripts", required: false)

</body>
</html>
@using Muebleria_Alpes_Web_Frontend.Mvc.ViewModels.RecursosHumanos
@model PuestoViewModel

<div class="modal fade" id="modalEditarPuesto-@Model.PuestoId" tabindex="-1" aria-labelledby="modalEditarPuestoLabel-@Model.PuestoId" aria-hidden="true">
    <div class="modal-dialog">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title" id="modalEditarPuestoLabel-@Model.PuestoId">
                    <i class="bi bi-pencil me-2"></i> Editar Puesto
                </h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Cerrar"></button>
            </div>
            <form asp-controller="Puestos" asp-action="Actualizar" asp-route-id="@Model.PuestoId" method="post">
                <div class="modal-body">
                    <div class="mb-3">
                        <label class="form-label">Nombre <span class="text-danger">*</span></label>
                        <input type="text" name="Nombre" class="form-control" required value="@Model.Nombre" />
                    </div>
                    <div class="mb-3">
                        <label class="form-label">Descripción</label>
                        <textarea name="Descripcion" class="form-control" rows="3">@Model.Descripcion</textarea>
                    </div>
                    <input type="hidden" name="UsuarioId" value="1" />
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancelar</button>
                    <button type="submit" class="btn btn-primary">
                        <i class="bi bi-save"></i> Actualizar
                    </button>
                </div>
            </form>
        </div>
    </div>
</div>

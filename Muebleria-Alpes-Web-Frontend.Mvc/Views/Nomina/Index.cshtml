@using Muebleria_Alpes_Web_Frontend.Mvc.ViewModels.RecursosHumanos
@model List<NominaViewModel>

@{
    ViewData["Title"] = "Nómina";
}

<div class="page-header">
    <div class="page-title-box">
        <div class="page-icon">
            <i class="bi bi-cash-stack"></i>
        </div>
        <div>
            <h1>Nómina</h1>
            <p>Gestión de nóminas del personal</p>
        </div>
    </div>

    <div class="page-actions">
        <button class="btn btn-primary btn-main" data-bs-toggle="modal" data-bs-target="#modalCrearNomina">
            <i class="bi bi-plus-lg"></i> Nueva Nómina
        </button>
    </div>
</div>

@if (TempData["Success"] != null)
{
    <div class="alert alert-success">@TempData["Success"]</div>
}

@if (TempData["Error"] != null)
{
    <div class="alert alert-danger">@TempData["Error"]</div>
}

<div class="record-count">
    @Model.Count registros
</div>

<div class="erp-card">
    <div class="table-responsive">
        <table class="table erp-table">
            <thead>
                <tr>
                    <th>Período</th>
                    <th>Fecha Inicio</th>
                    <th>Fecha Fin</th>
                    <th>Estado</th>
                    <th class="text-end">Acciones</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var nomina in Model)
                {
                    <tr>
                        <td>@(nomina.Periodo ?? "—")</td>
                        <td>@nomina.FechaInicio.ToString("dd/MM/yyyy")</td>
                        <td>@nomina.FechaFin.ToString("dd/MM/yyyy")</td>
                        <td>
                            @{
                                var badgeClass = nomina.Estado switch
                                {
                                    "BORRADOR" => "status-badge status-inactive",
                                    "PROCESADA" => "status-badge status-warning",
                                    "PAGADA" => "status-badge status-active",
                                    "ANULADA" => "status-badge status-inactive",
                                    _ => "status-badge status-inactive"
                                };
                            }
                            <span class="@badgeClass">@nomina.Estado</span>
                        </td>
                        <td class="text-end">
                            <div class="action-group">
                                <a asp-controller="Nomina"
                                   asp-action="Detalle"
                                   asp-route-id="@nomina.NominaId"
                                   class="btn-icon btn-detail"
                                   title="Ver detalle">
                                    <i class="bi bi-eye"></i>
                                </a>

                                @if (nomina.Estado == "BORRADOR")
                                {
                                    <form asp-controller="Nomina" asp-action="CambiarEstado" asp-route-id="@nomina.NominaId" method="post" class="d-inline">
                                        <input type="hidden" name="estado" value="PROCESADA" />
                                        <button type="submit" class="btn-icon btn-edit" title="Procesar">
                                            <i class="bi bi-play-circle"></i>
                                        </button>
                                    </form>
                                }

                                @if (nomina.Estado == "PROCESADA")
                                {
                                    <form asp-controller="Nomina" asp-action="CambiarEstado" asp-route-id="@nomina.NominaId" method="post" class="d-inline">
                                        <input type="hidden" name="estado" value="PAGADA" />
                                        <button type="submit" class="btn-icon btn-activate" title="Marcar como pagada">
                                            <i class="bi bi-check-circle"></i>
                                        </button>
                                    </form>
                                }

                                @if (nomina.Estado != "ANULADA" && nomina.Estado != "PAGADA")
                                {
                                    <form asp-controller="Nomina" asp-action="CambiarEstado" asp-route-id="@nomina.NominaId" method="post" class="d-inline">
                                        <input type="hidden" name="estado" value="ANULADA" />
                                        <button type="submit" class="btn-icon btn-delete" title="Anular">
                                            <i class="bi bi-x-circle"></i>
                                        </button>
                                    </form>
                                }
                            </div>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>

@await Html.PartialAsync("_CrearNominaModal", new CrearNominaViewModel())

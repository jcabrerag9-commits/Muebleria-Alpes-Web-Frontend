@using Muebleria_Alpes_Web_Frontend.Mvc.ViewModels
@model List<ClienteViewModel>

@{
    ViewData["Title"] = "Clientes";
}

<div class="page-header">
    <div class="page-title-box">
        <div class="page-icon">
            <i class="bi bi-person-lines-fill"></i>
        </div>
        <div>
            <h1>Clientes</h1>
            <p>Gestión de clientes registrados</p>
        </div>
    </div>

    <div class="page-actions">
        <input type="text" id="buscarCliente" class="form-control search-input" placeholder="Buscar..." />
        <button class="btn btn-primary btn-main" data-bs-toggle="modal" data-bs-target="#modalCrearCliente">
            <i class="bi bi-plus-lg"></i> Nuevo Cliente
        </button>
    </div>
</div>

@if (TempData["Success"] != null)
{
    <div class="alert alert-success">@TempData["Success"]</div>
}

@if (TempData["Error"] != null)
{
    <div class="alert alert-danger">@TempData["Error"]</div>
}

<div class="record-count">
    @Model.Count registros
</div>

<div class="erp-card">
    <div class="table-responsive">
        <table class="table erp-table" id="tablaClientes">
            <thead>
                <tr>
                    <th>Código</th>
                    <th>Nombre</th>
                    <th>Documento</th>
                    <th>Estado</th>
                    <th class="text-end">Acciones</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var cliente in Model)
                {
                    var iniciales = string.Join("", (cliente.NombreCompleto ?? "NA")
                        .Split(" ", StringSplitOptions.RemoveEmptyEntries)
                        .Take(2)
                        .Select(x => x[0]))
                        .ToUpper();

                    <tr>
                        <td>
                            <span class="code-badge">@(cliente.Codigo ?? "-")</span>
                        </td>

                        <td>
                            <div class="employee-cell">
                                <div class="employee-avatar">@iniciales</div>
                                <div>
                                    <div class="employee-name">@cliente.NombreCompleto</div>
                                    <div class="employee-subtitle">Cliente registrado</div>
                                </div>
                            </div>
                        </td>

                        <td>
                            <div class="doc-cell">
                                <strong>Tipo @cliente.TipoDocumentoId</strong>
                                <span>@(string.IsNullOrWhiteSpace(cliente.NumeroDocumento) ? "Sin documento" : cliente.NumeroDocumento)</span>
                            </div>
                        </td>

                        <td>
                            @if (cliente.Estado == "ACTIVO")
                            {
                                <span class="status-badge status-active">
                                    <i class="bi bi-check-circle"></i> Activo
                                </span>
                            }
                            else if (cliente.Estado == "INACTIVO")
                            {
                                <span class="status-badge status-inactive">
                                    <i class="bi bi-x-circle"></i> Inactivo
                                </span>
                            }
                            else
                            {
                                <span class="status-badge status-warning">
                                    <i class="bi bi-dash-circle"></i> @(cliente.Estado ?? "N/A")
                                </span>
                            }
                        </td>

                        <td class="text-end">
                            <div class="action-group">
                                <button class="btn-icon btn-detail" type="button" data-id="@cliente.Id" title="Ver detalle">
                                    <i class="bi bi-eye"></i>
                                </button>

                                <form asp-controller="Clientes"
                                      asp-action="CambiarEstado"
                                      asp-route-id="@cliente.Id"
                                      method="post"
                                      class="d-inline">
                                    <input type="hidden" name="estadoActual" value="@cliente.Estado" />
                                    <button type="submit"
                                            class="btn-icon @(cliente.Estado == "ACTIVO" ? "btn-edit" : "btn-edit")"
                                            title="Cambiar estado">
                                        @if (cliente.Estado == "ACTIVO")
                                        {
                                            <i class="bi bi-x-circle"></i>
                                        }
                                        else
                                        {
                                            <i class="bi bi-check-circle"></i>
                                        }
                                    </button>
                                </form>
                            </div>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>

@await Html.PartialAsync("_CrearClienteModal", new CrearClienteViewModel())

<div id="detalleClienteContainer"></div>

@section Scripts {
    <script src="~/js/clientes.js" asp-append-version="true"></script>
}

@model List<Muebleria_Alpes_Web_Frontend.Mvc.ViewModels.EnvioModuloViewModel>
@{ ViewData["Title"] = "Envíos"; var estadoActual = ViewBag.Estado as string ?? "PREPARANDO"; }
<div class="crud-page">
  <div class="d-flex justify-content-between align-items-center mb-4"><div><h1>Gestión de envíos</h1><p class="text-muted">Control logístico por estado, guía y confirmación de entrega.</p></div><a class="btn btn-danger" asp-action="Crear"><i class="bi bi-truck"></i> Crear envío</a></div>
  @if (TempData["Success"] is not null){<div class="alert alert-success">@TempData["Success"]</div>} @if (TempData["Error"] is not null){<div class="alert alert-danger">@TempData["Error"]</div>}
  <div class="card border-0 shadow-sm rounded-4 mb-3"><div class="card-body d-flex gap-2 flex-wrap"><span class="fw-semibold me-2">Estado:</span>@foreach(var e in new[]{"PREPARANDO","EN_TRANSITO","ENTREGADO","CANCELADO"}){<a class="btn btn-sm @(estadoActual==e?"btn-danger":"btn-outline-danger")" asp-route-estado="@e">@e</a>}</div></div>
  <div class="card border-0 shadow-sm rounded-4"><div class="table-responsive"><table class="table align-middle mb-0"><thead class="table-light"><tr><th>ID</th><th>Orden</th><th>Guía</th><th>Transportista</th><th>Costo</th><th>Estado</th><th class="text-end">Acciones</th></tr></thead><tbody>
  @foreach(var e in Model){<tr><td>@e.EnvioId</td><td>@e.OrdenVentaId</td><td class="fw-semibold">@e.NumeroGuia</td><td>@e.Transportista</td><td>Q @e.CostoEnvio.ToString("N2")</td><td><span class="badge bg-info text-dark">@e.Estado</span></td><td class="text-end"><form class="d-inline" asp-action="CambiarEstado" method="post"><input type="hidden" name="envioId" value="@e.EnvioId"/><select class="form-select form-select-sm d-inline w-auto" name="estado"><option>PREPARANDO</option><option>EN_TRANSITO</option><option>ENTREGADO</option><option>CANCELADO</option></select><button class="btn btn-sm btn-outline-primary">Cambiar</button></form> <form class="d-inline" asp-action="ConfirmarEntrega" method="post"><input type="hidden" name="envioId" value="@e.EnvioId"/><button class="btn btn-sm btn-outline-success">Confirmar entrega</button></form></td></tr>}
  </tbody></table></div></div>
</div>

@using Muebleria_Alpes_Web_Frontend.Mvc.ViewModels
@{ ViewData["Title"] = "Crear envío"; var ordenes = ViewBag.Ordenes as List<FiltroOrdenDisponibleResponse> ?? new(); }
<div class="crud-page">
  <h1>Crear envío</h1><p class="text-muted">Selecciona una orden disponible y registra los datos logísticos.</p>
  @if (TempData["Success"] is not null){<div class="alert alert-success">@TempData["Success"]</div>} @if (TempData["Error"] is not null){<div class="alert alert-danger">@TempData["Error"]</div>}
  <div class="card border-0 shadow-sm rounded-4"><div class="card-body"><form asp-action="Crear" method="post" class="row g-3">
    <div class="col-md-6"><label class="form-label">Orden disponible</label><select class="form-select" name="ordenVentaId" id="ordenSelect" required><option value="">Seleccione...</option>@foreach(var o in ordenes){<option value="@o.OrdenVentaId" data-cliente="@o.ClienteId">@o.NumeroOrden - @o.ClienteNombre - Q @o.Total.ToString("N2")</option>}</select></div>
    <div class="col-md-6"><label class="form-label">Dirección de cliente</label><select class="form-select" name="clienteDireccionId" id="direccionSelect" required><option value="">Seleccione una orden primero...</option></select></div>
    <div class="col-md-4"><label class="form-label">Número de guía</label><input class="form-control" name="numeroGuia" required/></div>
    <div class="col-md-4"><label class="form-label">Transportista</label><input class="form-control" name="transportista" required/></div>
    <div class="col-md-2"><label class="form-label">Costo</label><input class="form-control" type="number" step="0.01" name="costoEnvio" required/></div>
    <div class="col-md-2"><label class="form-label">Estado</label><select class="form-select" name="estado"><option>PREPARANDO</option><option>EN_TRANSITO</option></select></div>
    <div class="col-12"><button class="btn btn-danger">Registrar envío</button> <a class="btn btn-outline-secondary" asp-action="Index">Volver</a></div>
  </form></div></div>
</div>
@section Scripts{<script>
const orden = document.getElementById('ordenSelect'); const dir = document.getElementById('direccionSelect');
orden?.addEventListener('change', async () => { const cliente = orden.selectedOptions[0]?.dataset.cliente; dir.innerHTML='<option>Cargando...</option>'; if(!cliente){dir.innerHTML='<option>Seleccione una orden primero...</option>'; return;} const r=await fetch(`/Envios/DireccionesCliente?clienteId=${cliente}`); const data=await r.json(); dir.innerHTML=data.length?data.map(d=>`<option value="${d.clienteDireccionId}">${d.tipo} - ${d.direccion} (${d.ciudadNombre})</option>`).join(''):'<option value="">Sin direcciones activas</option>'; });
</script>}

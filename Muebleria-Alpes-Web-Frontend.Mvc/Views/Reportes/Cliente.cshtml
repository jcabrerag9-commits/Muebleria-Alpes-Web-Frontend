@using Muebleria_Alpes_Web_Frontend.Mvc.ViewModels
@{ ViewData["Title"] = "Reportes de clientes"; var clientes = ViewBag.Clientes as List<FiltroClienteResponse> ?? new(); }
<div class="crud-page"><h1>Reportes de clientes</h1><p class="text-muted">Selecciona un cliente y un rango de fechas.</p>
<div class="card border-0 shadow-sm rounded-4 mb-4"><div class="card-body"><form id="formReporteCliente" class="row g-3">@Html.AntiForgeryToken()<div class="col-md-4"><label class="form-label">Cliente</label><select class="form-select" name="clienteId">@foreach(var c in clientes){<option value="@c.ClienteId">@c.Codigo - @c.Nombre</option>}</select></div><div class="col-md-3"><label class="form-label">Fecha inicio</label><input class="form-control" type="date" name="fechaInicio" value="2026-01-01"/></div><div class="col-md-3"><label class="form-label">Fecha fin</label><input class="form-control" type="date" name="fechaFin" value="2026-12-31"/></div><div class="col-md-2 d-flex align-items-end"><button class="btn btn-danger w-100">Consultar</button></div></form></div></div>
<div id="resultadoReporte" class="row g-3"></div></div>
@section Scripts{<script>
function val(obj,key){try{const o=JSON.parse(obj);return o.data?.[key]??o[key]??0}catch{return 0}}
document.getElementById('formReporteCliente').addEventListener('submit',async e=>{e.preventDefault();const fd=new FormData(e.target);const r=await fetch('/Reportes/ClienteResultado',{method:'POST',body:fd});const j=await r.json();resultadoReporte.innerHTML=`<div class="col-md-4"><div class="card border-0 shadow-sm rounded-4"><div class="card-body"><span class="text-muted">Total compras</span><h3>Q ${val(j.total,'totalCompras')}</h3></div></div></div><div class="col-md-4"><div class="card border-0 shadow-sm rounded-4"><div class="card-body"><span class="text-muted">LTV</span><h3>Q ${val(j.ltv,'ltv')}</h3></div></div></div><div class="col-md-4"><div class="card border-0 shadow-sm rounded-4"><div class="card-body"><span class="text-muted">Ticket promedio</span><h3>Q ${val(j.ticket,'ticketPromedio')}</h3></div></div></div>`;});
</script>}

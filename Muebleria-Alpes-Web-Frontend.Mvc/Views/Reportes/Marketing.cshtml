@using Muebleria_Alpes_Web_Frontend.Mvc.ViewModels
@{ ViewData["Title"] = "Reportes de marketing"; var clientes = ViewBag.Clientes as List<FiltroClienteResponse> ?? new(); }
<div class="crud-page"><h1>Reportes de marketing</h1><p class="text-muted">LTV, tasa de retención y tasa de conversión.</p>
<div class="card border-0 shadow-sm rounded-4 mb-4"><div class="card-body"><form id="formReporteMarketing" class="row g-3">@Html.AntiForgeryToken()<div class="col-md-4"><label class="form-label">Cliente</label><select class="form-select" name="clienteId">@foreach(var c in clientes){<option value="@c.ClienteId">@c.Codigo - @c.Nombre</option>}</select></div><div class="col-md-3"><label class="form-label">Fecha inicio</label><input class="form-control" type="date" name="fechaInicio" value="2026-01-01"/></div><div class="col-md-3"><label class="form-label">Fecha fin</label><input class="form-control" type="date" name="fechaFin" value="2026-12-31"/></div><div class="col-md-2 d-flex align-items-end"><button class="btn btn-danger w-100">Consultar</button></div></form></div></div><div id="resultadoReporte" class="row g-3"></div></div>
@section Scripts{<script>
function val(obj,key){try{const o=JSON.parse(obj);return o.data?.[key]??o[key]??0}catch{return 0}}
document.getElementById('formReporteMarketing').addEventListener('submit',async e=>{e.preventDefault();const fd=new FormData(e.target);const r=await fetch('/Reportes/MarketingResultado',{method:'POST',body:fd});const j=await r.json();resultadoReporte.innerHTML=`<div class="col-md-4"><div class="card border-0 shadow-sm rounded-4"><div class="card-body"><span class="text-muted">LTV cliente</span><h3>Q ${val(j.ltv,'ltv')}</h3></div></div></div><div class="col-md-4"><div class="card border-0 shadow-sm rounded-4"><div class="card-body"><span class="text-muted">Retención</span><h3>${val(j.retencion,'tasaRetencion')}%</h3></div></div></div><div class="col-md-4"><div class="card border-0 shadow-sm rounded-4"><div class="card-body"><span class="text-muted">Conversión</span><h3>${val(j.conversion,'tasaConversion')}%</h3></div></div></div>`;});
</script>}

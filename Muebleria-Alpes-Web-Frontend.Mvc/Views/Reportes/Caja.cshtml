@using Muebleria_Alpes_Web_Frontend.Mvc.ViewModels
@{ ViewData["Title"] = "Reportes de caja"; var cortes = ViewBag.Cortes as List<FiltroCorteCajaResponse> ?? new(); }
<div class="crud-page"><h1>Reportes de caja</h1><p class="text-muted">Consulta cortes, total de ventas y diferencia de caja.</p>
<div class="card border-0 shadow-sm rounded-4 mb-4"><div class="card-body"><form id="formReporteCaja" class="row g-3">@Html.AntiForgeryToken()<div class="col-md-3"><label class="form-label">Fecha inicio</label><input class="form-control" type="date" name="fechaInicio" value="2026-03-01"/></div><div class="col-md-3"><label class="form-label">Fecha fin</label><input class="form-control" type="date" name="fechaFin" value="2026-03-31"/></div><div class="col-md-3"><label class="form-label">Estado</label><select class="form-select" name="estado"><option>CERRADO</option><option>ABIERTO</option></select></div><div class="col-md-3"><label class="form-label">Corte</label><select class="form-select" name="corteCajaId">@foreach(var c in cortes){<option value="@c.CorteCajaId">#@c.CorteCajaId - @c.Estado - @(c.FechaCorte?.ToString("dd/MM/yyyy"))</option>}</select></div><div class="col-12"><button class="btn btn-danger">Consultar caja</button></div></form></div></div><div id="resultadoReporte" class="row g-3"></div></div>
@section Scripts{<script>
function val(obj,key){try{const o=JSON.parse(obj);return o.data?.[key]??o[key]??0}catch{return 0}}
document.getElementById('formReporteCaja').addEventListener('submit',async e=>{e.preventDefault();const fd=new FormData(e.target);const r=await fetch('/Reportes/CajaResultado',{method:'POST',body:fd});const j=await r.json();resultadoReporte.innerHTML=`<div class="col-md-4"><div class="card border-0 shadow-sm rounded-4"><div class="card-body"><span class="text-muted">Total ventas corte</span><h3>Q ${val(j.total,'totalVentas')}</h3></div></div></div><div class="col-md-4"><div class="card border-0 shadow-sm rounded-4"><div class="card-body"><span class="text-muted">Diferencia caja</span><h3>Q ${val(j.diferencia,'diferenciaCaja')}</h3></div></div></div><div class="col-md-4"><div class="card border-0 shadow-sm rounded-4"><div class="card-body"><span class="text-muted">Reporte</span><h3>Generado</h3><small class="text-muted">Ver cortes en filtro.</small></div></div></div>`;});
</script>}

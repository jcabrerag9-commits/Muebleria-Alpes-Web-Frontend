@{
    ViewData["Title"] = "Reportes";
}

<div class="page-header">
    <div class="page-title-box">
        <div class="page-icon"><i class="bi bi-bar-chart"></i></div>
        <div>
            <h1>Reportes</h1>
            <p>Análisis y estadísticas del negocio</p>
        </div>
    </div>
</div>

<div class="row g-4">
    <div class="col-md-4">
        <div class="erp-card text-center p-4">
            <i class="bi bi-graph-up-arrow fs-1 text-success mb-3 d-block"></i>
            <h5>Ventas por Período</h5>
            <p class="text-muted">Análisis de ventas diarias, semanales y mensuales</p>
            <button class="btn btn-outline-success btn-sm">Generar Reporte</button>
        </div>
    </div>
    <div class="col-md-4">
        <div class="erp-card text-center p-4">
            <i class="bi bi-people fs-1 text-primary mb-3 d-block"></i>
            <h5>Reporte de Clientes</h5>
            <p class="text-muted">LTV, retención y ticket promedio por cliente</p>
            <button class="btn btn-outline-primary btn-sm">Generar Reporte</button>
        </div>
    </div>
    <div class="col-md-4">
        <div class="erp-card text-center p-4">
            <i class="bi bi-box-seam fs-1 text-warning mb-3 d-block"></i>
            <h5>Inventario</h5>
            <p class="text-muted">Stock disponible y movimientos de bodega</p>
            <a asp-controller="Inventario" asp-action="Index" class="btn btn-outline-warning btn-sm">Ver Inventario</a>
        </div>
    </div>
    <div class="col-md-4">
        <div class="erp-card text-center p-4">
            <i class="bi bi-cash-stack fs-1 text-danger mb-3 d-block"></i>
            <h5>Reporte de Caja</h5>
            <p class="text-muted">Cortes de caja y conciliaciones</p>
            <a asp-controller="Caja" asp-action="Index" class="btn btn-outline-danger btn-sm">Ver Caja</a>
        </div>
    </div>
    <div class="col-md-4">
        <div class="erp-card text-center p-4">
            <i class="bi bi-tags fs-1 text-info mb-3 d-block"></i>
            <h5>Promociones</h5>
            <p class="text-muted">Efectividad y uso de promociones activas</p>
            <a asp-controller="Promociones" asp-action="Index" class="btn btn-outline-info btn-sm">Ver Promociones</a>
        </div>
    </div>
    <div class="col-md-4">
        <div class="erp-card text-center p-4">
            <i class="bi bi-person-gear fs-1 text-secondary mb-3 d-block"></i>
            <h5>RRHH</h5>
            <p class="text-muted">Asistencias, nóminas y evaluaciones</p>
            <a asp-controller="Empleados" asp-action="Index" class="btn btn-outline-secondary btn-sm">Ver Empleados</a>
        </div>
    </div>
</div>

@{ ViewData["Title"] = "Reportes"; }
<div class="crud-page">
  <h1>Centro de reportes</h1><p class="text-muted">Consulta indicadores de clientes, ventas, caja y marketing.</p>
  <div class="row g-4 mt-2">
    <div class="col-md-3"><a class="text-decoration-none" asp-action="Cliente"><div class="card border-0 shadow-sm rounded-4"><div class="card-body"><i class="bi bi-person-lines-fill fs-2 text-danger"></i><h5 class="mt-3 text-dark">Clientes</h5><p class="text-muted">Compras, LTV y ticket promedio.</p></div></div></a></div>
    <div class="col-md-3"><a class="text-decoration-none" asp-action="Ventas"><div class="card border-0 shadow-sm rounded-4"><div class="card-body"><i class="bi bi-graph-up-arrow fs-2 text-danger"></i><h5 class="mt-3 text-dark">Ventas</h5><p class="text-muted">Totales por rango, ciudad y canal.</p></div></div></a></div>
    <div class="col-md-3"><a class="text-decoration-none" asp-action="Caja"><div class="card border-0 shadow-sm rounded-4"><div class="card-body"><i class="bi bi-cash-stack fs-2 text-danger"></i><h5 class="mt-3 text-dark">Caja</h5><p class="text-muted">Cortes, ventas y diferencia.</p></div></div></a></div>
    <div class="col-md-3"><a class="text-decoration-none" asp-action="Marketing"><div class="card border-0 shadow-sm rounded-4"><div class="card-body"><i class="bi bi-megaphone fs-2 text-danger"></i><h5 class="mt-3 text-dark">Marketing</h5><p class="text-muted">Retención, conversión y LTV.</p></div></div></a></div>
  </div>
</div>

@using Muebleria_Alpes_Web_Frontend.Mvc.ViewModels
@{ ViewData["Title"] = "Reportes de ventas"; var canales = ViewBag.Canales as List<FiltroCanalVentaResponse> ?? new(); var ciudades = ViewBag.Ciudades as List<FiltroCiudadResponse> ?? new(); }
<div class="crud-page"><h1>Reportes de ventas</h1><p class="text-muted">Totales por rango, ciudad y canal de venta.</p>
<div class="card border-0 shadow-sm rounded-4 mb-4"><div class="card-body"><form id="formReporteVentas" class="row g-3">@Html.AntiForgeryToken()<div class="col-md-3"><label class="form-label">Fecha inicio</label><input class="form-control" type="date" name="fechaInicio" value="2026-01-01"/></div><div class="col-md-3"><label class="form-label">Fecha fin</label><input class="form-control" type="date" name="fechaFin" value="2026-12-31"/></div><div class="col-md-3"><label class="form-label">Ciudad</label><select class="form-select" name="ciudadId">@foreach(var c in ciudades){<option value="@c.CiudadId">@c.Codigo - @c.Nombre</option>}</select></div><div class="col-md-3"><label class="form-label">Canal</label><select class="form-select" name="canalVentaId">@foreach(var c in canales){<option value="@c.CanalVentaId">@c.Codigo - @c.Nombre</option>}</select></div><div class="col-12"><button class="btn btn-danger">Consultar ventas</button></div></form></div></div><div id="resultadoReporte" class="row g-3"></div></div>
@section Scripts{<script>
function val(obj,key){try{const o=JSON.parse(obj);return o.data?.[key]??o[key]??0}catch{return 0}}
document.getElementById('formReporteVentas').addEventListener('submit',async e=>{e.preventDefault();const fd=new FormData(e.target);const r=await fetch('/Reportes/VentasResultado',{method:'POST',body:fd});const j=await r.json();resultadoReporte.innerHTML=`<div class="col-md-4"><div class="card border-0 shadow-sm rounded-4"><div class="card-body"><span class="text-muted">Total rango</span><h3>Q ${val(j.total,'totalVentas')}</h3></div></div></div><div class="col-md-4"><div class="card border-0 shadow-sm rounded-4"><div class="card-body"><span class="text-muted">Total ciudad</span><h3>Q ${val(j.ciudad,'totalVentas')}</h3></div></div></div><div class="col-md-4"><div class="card border-0 shadow-sm rounded-4"><div class="card-body"><span class="text-muted">Ingresos canal</span><h3>Q ${val(j.canal,'totalIngresos')}</h3></div></div></div>`;});
</script>}

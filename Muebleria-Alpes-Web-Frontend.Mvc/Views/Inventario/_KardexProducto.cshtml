@using Muebleria_Alpes_Web_Frontend.Mvc.ViewModels.Inventario
@model List<KardexMovimientoViewModel>

<div class="kardex-timeline p-3">
    @if (Model == null || !Model.Any())
    {
        <div class="text-center py-5">
            <i class="bi bi-clock-history d-block mb-3" style="font-size: 3rem; color: #dee2e6;"></i>
            <h6 class="text-muted fw-bold">Sin movimientos registrados</h6>
            <p class="small text-muted">Este producto aún no tiene historial en el Kardex.</p>
        </div>
    }
    else
    {
        <div class="timeline-container position-relative">
            <!-- Línea Vertical -->
            <div class="timeline-line position-absolute h-100" style="width: 2px; background: #e9ecef; left: 15px; top: 0; z-index: 0;"></div>

            @foreach (var mov in Model.OrderByDescending(x => x.Fecha))
            {
                <div class="timeline-item position-relative mb-4 ps-5">
                    <!-- Punto en el timeline -->
                    <div class="timeline-dot position-absolute @mov.BadgeClass d-flex align-items-center justify-content-center shadow-sm" 
                         style="width: 32px; height: 32px; left: 0; top: 0; border-radius: 50%; z-index: 1; border: 3px solid #fff;">
                        <i class="bi @mov.Icon text-white" style="font-size: .85rem;"></i>
                    </div>

                    <!-- Contenido del Card -->
                    <div class="card border-0 shadow-sm" style="background: #fdfdfe; border-radius: 12px; border: 1px solid #f1f3f5 !important;">
                        <div class="card-body p-3">
                            <div class="d-flex justify-content-between align-items-start mb-2">
                                <div>
                                    <h6 class="mb-0 fw-bold" style="color: #343a40;">@mov.TipoMovimiento</h6>
                                    <small class="text-muted" style="font-size: .75rem;">
                                        <i class="bi bi-clock me-1"></i>@mov.Fecha.ToString("dd/MM/yyyy HH:mm")
                                    </small>
                                </div>
                                <span class="badge @mov.BadgeClass rounded-pill px-3 py-2" style="font-size: .85rem;">
                                    @(mov.Cantidad > 0 ? "+" : "")@mov.Cantidad
                                </span>
                            </div>

                            <div class="row g-2 mb-2">
                                <div class="col-6">
                                    <div class="p-2 rounded" style="background: #f8f9fa; border: 1px dashed #dee2e6;">
                                        <small class="d-block text-muted text-uppercase fw-bold" style="font-size: .6rem; letter-spacing: .05em;">Stock Anterior</small>
                                        <span class="fw-bold" style="color: #495057;">@mov.StockAnterior</span>
                                    </div>
                                </div>
                                <div class="col-6">
                                    <div class="p-2 rounded" style="background: #e7f5ff; border: 1px solid #d0ebff;">
                                        <small class="d-block text-primary text-uppercase fw-bold" style="font-size: .6rem; letter-spacing: .05em;">Nuevo Stock</small>
                                        <span class="fw-bold text-primary">@mov.StockNuevo</span>
                                    </div>
                                </div>
                            </div>

                            @if (!string.IsNullOrEmpty(mov.Observacion))
                            {
                                <div class="bg-light p-2 rounded mb-2" style="font-size: .82rem; color: #6c757d; border-left: 3px solid #dee2e6;">
                                    <i class="bi bi-chat-left-text me-2"></i>@mov.Observacion
                                </div>
                            }

                            <div class="d-flex align-items-center justify-content-between pt-2 border-top mt-2" style="font-size: .75rem;">
                                <div class="text-muted">
                                    <i class="bi bi-person-circle me-1"></i>@(mov.UsuarioNombre ?? "Sistema")
                                </div>
                                <div class="text-muted">
                                    <i class="bi bi-building me-1"></i>@(mov.NombreBodega ?? "Sin Bodega")
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            }
        </div>
    }
</div>

<style>
    .kardex-timeline {
        max-height: 600px;
        overflow-y: auto;
        scrollbar-width: thin;
    }
    .kardex-timeline::-webkit-scrollbar {
        width: 6px;
    }
    .kardex-timeline::-webkit-scrollbar-thumb {
        background: #dee2e6;
        border-radius: 10px;
    }
    .timeline-item:last-child .timeline-line {
        display: none;
    }
    .card {
        transition: transform 0.2s ease-in-out;
    }
    .card:hover {
        transform: translateX(5px);
    }
</style>

@using Muebleria_Alpes_Web_Frontend.Mvc.ViewModels.Inventario
@model InventarioDashboardViewModel

@{
    ViewData["Title"] = "Dashboard de Inventario";
}

<div class="container-fluid px-4 py-4">
    <h3 class="fw-bold mb-1" style="color: #1f1f24;">Resumen de Inventarios</h3>
    <p class="text-muted small mb-4">Métricas clave y estado actual del almacén.</p>

    <!-- KPI Widgets -->
    <div class="row g-3 mb-4">
        <div class="col-md-3">
            <div class="card border-0 shadow-sm p-4 text-center h-100" style="border-radius: 16px;">
                <div class="rounded-circle bg-light d-flex align-items-center justify-content-center mx-auto mb-3" style="width: 60px; height: 60px;">
                    <i class="bi bi-exclamation-triangle fs-3 text-warning"></i>
                </div>
                <h2 class="fw-bold m-0">@Model.ProductosStockBajo</h2>
                <p class="text-muted small text-uppercase fw-bold mb-0" style="letter-spacing: .05em;">Stock Bajo</p>
            </div>
        </div>
        <div class="col-md-3">
            <div class="card border-0 shadow-sm p-4 text-center h-100" style="border-radius: 16px;">
                <div class="rounded-circle bg-light d-flex align-items-center justify-content-center mx-auto mb-3" style="width: 60px; height: 60px;">
                    <i class="bi bi-box-seam fs-3 text-success"></i>
                </div>
                <h2 class="fw-bold m-0">@Model.AtpTotal</h2>
                <p class="text-muted small text-uppercase fw-bold mb-0" style="letter-spacing: .05em;">ATP Total</p>
            </div>
        </div>
        <div class="col-md-3">
            <div class="card border-0 shadow-sm p-4 text-center h-100" style="border-radius: 16px;">
                <div class="rounded-circle bg-light d-flex align-items-center justify-content-center mx-auto mb-3" style="width: 60px; height: 60px;">
                    <i class="bi bi-bookmark-check fs-3 text-primary"></i>
                </div>
                <h2 class="fw-bold m-0">@Model.ReservasActivasCount</h2>
                <p class="text-muted small text-uppercase fw-bold mb-0" style="letter-spacing: .05em;">Reservas Activas</p>
            </div>
        </div>
        <div class="col-md-3">
            <div class="card border-0 shadow-sm p-4 text-center h-100" style="border-radius: 16px;">
                <div class="rounded-circle bg-light d-flex align-items-center justify-content-center mx-auto mb-3" style="width: 60px; height: 60px;">
                    <i class="bi bi-arrow-repeat fs-3 text-info"></i>
                </div>
                <h2 class="fw-bold m-0">@Model.MovimientosHoyCount</h2>
                <p class="text-muted small text-uppercase fw-bold mb-0" style="letter-spacing: .05em;">Movimientos Hoy</p>
            </div>
        </div>
    </div>

    <div class="row g-4">
        <!-- Ocupación de Bodegas -->
        <div class="col-md-6">
            <div class="card border-0 shadow-sm p-4" style="border-radius: 16px; min-height: 400px;">
                <h6 class="fw-bold mb-4"><i class="bi bi-building me-2"></i>Ocupación por Bodega</h6>
                @if (Model.OcupacionBodegas == null || !Model.OcupacionBodegas.Any())
                {
                    <div class="text-center py-5 opacity-50">
                        <i class="bi bi-inbox fs-1"></i>
                        <p>No hay datos de ocupación.</p>
                    </div>
                }
                else
                {
                    @foreach (var b in Model.OcupacionBodegas)
                    {
                        <div class="mb-4">
                            <div class="d-flex justify-content-between mb-1">
                                <span class="fw-bold small">@b.Nombre</span>
                                <span class="text-muted small">@b.Cantidad un. (@b.Porcentaje%)</span>
                            </div>
                            <div class="progress" style="height: 10px; border-radius: 5px;">
                                <div class="progress-bar" role="progressbar" style="width: @b.Porcentaje%; background: #0d6efd;" 
                                     aria-valuenow="@b.Porcentaje" aria-valuemin="0" aria-valuemax="100"></div>
                            </div>
                        </div>
                    }
                }
            </div>
        </div>

        <!-- Atajos Rápidos -->
        <div class="col-md-6">
            <div class="card border-0 shadow-sm p-4 h-100" style="border-radius: 16px;">
                <h6 class="fw-bold mb-4"><i class="bi bi-lightning-charge me-2"></i>Acciones Rápidas</h6>
                <div class="list-group list-group-flush border-0">
                    <a href="@Url.Action("Index", "Inventario")" class="list-group-item list-group-item-action border-0 px-0 py-3 d-flex align-items-center">
                        <div class="rounded-circle bg-success bg-opacity-10 text-success p-2 me-3">
                            <i class="bi bi-box-seam"></i>
                        </div>
                        <div>
                            <div class="fw-bold">Ver Catálogo de Productos</div>
                            <small class="text-muted">Consultar existencias y movimientos.</small>
                        </div>
                        <i class="bi bi-chevron-right ms-auto text-muted"></i>
                    </a>
                    <a href="@Url.Action("Bodegas", "Inventario")" class="list-group-item list-group-item-action border-0 px-0 py-3 d-flex align-items-center">
                        <div class="rounded-circle bg-primary bg-opacity-10 text-primary p-2 me-3">
                            <i class="bi bi-building"></i>
                        </div>
                        <div>
                            <div class="fw-bold">Administrar Bodegas</div>
                            <small class="text-muted">Crear o editar almacenes del sistema.</small>
                        </div>
                        <i class="bi bi-chevron-right ms-auto text-muted"></i>
                    </a>
                </div>
            </div>
        </div>
    </div>
</div>

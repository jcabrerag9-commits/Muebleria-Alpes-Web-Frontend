@using Muebleria_Alpes_Web_Frontend.Mvc.ViewModels.Productos
@model List<ProductoViewModel>

@{
    ViewData["Title"] = "Productos";
}

<div class="page-header">
    <div class="page-title-box">
        <div class="page-icon">
            <i class="bi bi-box-seam"></i>
        </div>
        <div>
            <h1>Productos</h1>
            <p>Catálogo de muebles</p>
        </div>
    </div>

    <div class="page-actions">
        <input type="text" id="buscarProducto" class="form-control search-input" placeholder="Buscar..." />
        <button class="btn btn-primary btn-main" data-bs-toggle="modal" data-bs-target="#modalCrearProducto">
            <i class="bi bi-plus-lg"></i> Nuevo Producto
        </button>
    </div>
</div>

@if (TempData["Success"] != null)
{
    <div class="alert alert-success">@TempData["Success"]</div>
}

@if (TempData["Error"] != null)
{
    <div class="alert alert-danger">@TempData["Error"]</div>
}

<div class="record-count">
    @Model.Count registros
</div>

<div class="erp-card">
    <div class="table-responsive">
        <table class="table erp-table" id="tablaProductos">
            <thead>
                <tr>
                    <th>Código</th>
                    <th>Nombre</th>
                    <th>SKU</th>
                    <th>Tipo Mueble</th>
                    <th>Estado</th>
                    <th class="text-end">Acciones</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var item in Model)
                {
                    var iniciales = string.Join("", (item.Nombre ?? "PR")
                        .Split(" ", StringSplitOptions.RemoveEmptyEntries)
                        .Take(2)
                        .Select(x => x[0]))
                        .ToUpper();

                    <tr>
                        <td>
                            <span class="code-badge">@(item.Sku ?? $"#{item.Id}")</span>
                        </td>

                        <td>
                            <div class="employee-cell">
                                <div class="employee-avatar">@iniciales</div>
                                <div>
                                    <div class="employee-name">@item.Nombre</div>
                                    <div class="employee-subtitle">@item.Descripcion</div>
                                </div>
                            </div>
                        </td>

                        <td>
                            <span class="code-badge">@(item.Sku ?? "-")</span>
                        </td>

                        <td>
                            <span>Tipo @item.TipoMuebleId</span>
                        </td>

                        <td>
                            @if (item.Estado == "ACTIVO")
                            {
                                <span class="status-badge status-active">
                                    <i class="bi bi-check-circle"></i> Activo
                                </span>
                            }
                            else
                            {
                                <span class="status-badge status-inactive">
                                    <i class="bi bi-x-circle"></i> Inactivo
                                </span>
                            }
                        </td>

                        <td class="text-end">
                            <div class="action-group">
                                <button class="btn-icon btn-detail"
                                        type="button"
                                        data-id="@item.Id"
                                        title="Ver detalle">
                                    <i class="bi bi-eye"></i>
                                </button>

                                <button class="btn-icon btn-edit"
                                        type="button"
                                        data-bs-toggle="modal"
                                        data-bs-target="#modalEditarProducto-@item.Id"
                                        title="Editar">
                                    <i class="bi bi-pencil"></i>
                                </button>

                                <form asp-controller="Productos"
                                      asp-action="CambiarEstado"
                                      asp-route-id="@item.Id"
                                      method="post"
                                      class="d-inline">
                                    <input type="hidden" name="estadoActual" value="@item.Estado" />
                                    <button type="submit"
                                            class="btn-icon @(item.Estado == "ACTIVO" ? "btn-delete" : "btn-activate")"
                                            title="Cambiar estado">
                                        @if (item.Estado == "ACTIVO")
                                        {
                                            <i class="bi bi-x-circle"></i>
                                        }
                                        else
                                        {
                                            <i class="bi bi-check-circle"></i>
                                        }
                                    </button>
                                </form>

                                <form asp-controller="Productos"
                                      asp-action="Eliminar"
                                      asp-route-id="@item.Id"
                                      method="post"
                                      class="d-inline"
                                      onsubmit="return confirm('¿Eliminar este producto?');">
                                    <button type="submit" class="btn-icon btn-delete" title="Eliminar">
                                        <i class="bi bi-trash"></i>
                                    </button>
                                </form>
                            </div>
                        </td>
                    </tr>

                    @await Html.PartialAsync("_EditarProductoModal", item)
                }
            </tbody>
        </table>
    </div>
</div>

@await Html.PartialAsync("_CrearProductoModal", new CrearProductoViewModel())

<div id="detalleContainer"></div>

<div class="modal fade" id="modalDetalle" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-lg modal-dialog-centered modal-dialog-scrollable">
        <div class="modal-content erp-modal" id="detalleProductoContent">
        </div>
    </div>
</div>

@section Scripts {
    <script src="~/js/productos/productos.js" asp-append-version="true"></script>
}

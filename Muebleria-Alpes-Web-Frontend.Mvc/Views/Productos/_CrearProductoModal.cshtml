@using Muebleria_Alpes_Web_Frontend.Mvc.ViewModels.Productos
@model CrearProductoViewModel

<div class="modal fade" id="modalCrearProducto" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-lg">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title"><i class="bi bi-plus-circle me-2"></i> Nuevo Producto</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <form asp-controller="Productos" asp-action="Crear" method="post" class="form-crear-producto">
                <div class="modal-body">
                    <div class="alert alert-danger d-none form-error-alert" role="alert"></div>
                    <div class="row g-3">
                        <div class="col-md-8">
                            <label asp-for="Nombre" class="form-label">Nombre del Producto <span class="text-danger">*</span></label>
                            <input asp-for="Nombre" class="form-control" required />
                        </div>
                        
                        <div class="col-md-4">
                            <label asp-for="TipoMueble" class="form-label">Tipo de Mueble <span class="text-danger">*</span></label>
                            <select asp-for="TipoMueble" class="form-select" required>
                                <option value="">Seleccione un tipo...</option>
                            </select>
                        </div>

                        <div class="col-md-12">
                            <label asp-for="DescripcionCorta" class="form-label">Descripción Corta</label>
                            <input asp-for="DescripcionCorta" class="form-control" />
                        </div>

                        <div class="col-md-12">
                            <label asp-for="DescripcionLarga" class="form-label">Descripción Larga</label>
                            <textarea asp-for="DescripcionLarga" class="form-control" rows="3"></textarea>
                        </div>

                        <div class="col-md-6">
                            <label asp-for="Peso" class="form-label">Peso (kg)</label>
                            <input asp-for="Peso" class="form-control" type="number" step="0.01" />
                        </div>

                        <div class="col-md-6">
                            <label asp-for="EsConfigurable" class="form-label">Es Configurable</label>
                            <select asp-for="EsConfigurable" class="form-select">
                                <option value="N">No (Producto Simple)</option>
                                <option value="S">Sí (Múltiples Variantes)</option>
                            </select>
                        </div>

                        <div class="col-md-6">
                            <label asp-for="PrecioVigente" class="form-label">Precio Regular (Q) <span class="text-danger">*</span></label>
                            <input asp-for="PrecioVigente" class="form-control" type="number" step="0.01" placeholder="0.00" required />
                        </div>

                        <div class="col-md-6">
                            <label asp-for="PrecioOferta" class="form-label">Precio Oferta (Opcional)</label>
                            <input asp-for="PrecioOferta" class="form-control" type="number" step="0.01" placeholder="0.00" />
                        </div>
                    </div>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancelar</button>
                    <button type="submit" class="btn btn-primary btn-submit-crear">Guardar Producto</button>
                </div>
            </form>
        </div>
    </div>
</div>

@using Muebleria_Alpes_Web_Frontend.Mvc.ViewModels.Productos
@model ProductoViewModel

<div class="modal fade" id="modalEditarProducto-@Model.ProductoId" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-lg">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title"><i class="bi bi-pencil me-2"></i> Editar Producto: @Model.Nombre</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <form asp-controller="Productos" asp-action="Actualizar" asp-route-id="@Model.ProductoId" method="post" class="form-editar-producto">
                <div class="modal-body">
                    <div class="alert alert-danger d-none form-error-alert"></div>
                    <div class="row g-3">
                        <div class="col-md-8">
                            <label class="form-label">Nombre del Producto <span class="text-danger">*</span></label>
                            <input name="Nombre" class="form-control" value="@Model.Nombre" required />
                        </div>
                        
                        <div class="col-md-4">
                            <label class="form-label">Tipo de Mueble <span class="text-danger">*</span></label>
                            <select name="TipoMueble" class="form-select select-tipo-mueble" data-selected-value="@Model.TipoMuebleId" required>
                                <option value="">Seleccione un tipo...</option>
                                @if (Model.TipoMuebleId.HasValue)
                                {
                                    <option value="@Model.TipoMuebleId" selected>@Model.TipoMuebleNombre</option>
                                }
                            </select>
                        </div>
                        
                        <div class="col-md-12">
                            <label class="form-label">Descripción Corta</label>
                            <input name="DescripcionCorta" class="form-control" value="@Model.DescripcionCorta" />
                        </div>

                        <div class="col-md-6">
                            <label class="form-label">Peso (kg)</label>
                            <input name="Peso" class="form-control" type="number" step="0.01" value="@Model.Peso" />
                        </div>
                    </div>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancelar</button>
                    <button type="submit" class="btn btn-primary btn-submit-editar">Actualizar Producto</button>
                </div>
            </form>
        </div>
    </div>
</div>

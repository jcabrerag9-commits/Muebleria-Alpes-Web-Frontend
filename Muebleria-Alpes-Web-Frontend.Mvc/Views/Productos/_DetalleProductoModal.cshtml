@using Muebleria_Alpes_Web_Frontend.Mvc.ViewModels.Productos
@model ProductoViewModel

<div class="modal fade" id="modalDetalleProducto" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title"><i class="bi bi-card-text me-2"></i> Detalle del Producto</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body">
                <div class="text-center mb-4">
                    <div class="employee-avatar mx-auto mb-2" style="width: 80px; height: 80px; font-size: 2rem;">
                        <i class="bi bi-box"></i>
                    </div>
                    <h4 class="mb-0">@Model.Nombre</h4>
                    <span class="badge bg-secondary">SKU: @Model.Sku</span>
                </div>

                <ul class="list-group list-group-flush">
                    <li class="list-group-item d-flex justify-content-between align-items-center">
                        <span class="text-muted">Estado</span>
                        @if (Model.Estado == "ACTIVO")
                        {
                            <span class="badge bg-success">Activo</span>
                        }
                        else if (Model.Estado == "BORRADOR")
                        {
                            <span class="badge bg-warning text-dark">Borrador</span>
                        }
                        else
                        {
                            <span class="badge bg-danger">Inactivo</span>
                        }
                    </li>
                    <li class="list-group-item">
                        <small class="text-muted d-block">Descripción Corta</small>
                        <span>@(string.IsNullOrWhiteSpace(Model.DescripcionCorta) ? "N/A" : Model.DescripcionCorta)</span>
                    </li>
                    <li class="list-group-item">
                        <small class="text-muted d-block">Descripción Larga</small>
                        <span>@(string.IsNullOrWhiteSpace(Model.DescripcionLarga) ? "N/A" : Model.DescripcionLarga)</span>
                    </li>
                    <li class="list-group-item d-flex justify-content-between align-items-center">
                        <span class="text-muted">Peso</span>
                        <span>@(Model.Peso?.ToString("0.00") ?? "N/A") kg</span>
                    </li>
                    <li class="list-group-item d-flex justify-content-between align-items-center">
                        <span class="text-muted">Configurable</span>
                        <span>@(Model.EsConfigurable == "S" ? "Sí" : "No")</span>
                    </li>
                    <li class="list-group-item d-flex justify-content-between align-items-center">
                        <span class="text-muted">Fecha de Registro</span>
                        <span>@Model.FechaRegistro.ToString("dd/MM/yyyy HH:mm")</span>
                    </li>
                </ul>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cerrar</button>
            </div>
        </div>
    </div>
</div>

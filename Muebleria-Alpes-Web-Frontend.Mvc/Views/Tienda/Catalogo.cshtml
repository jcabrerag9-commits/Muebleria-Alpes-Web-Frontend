@using Muebleria_Alpes_Web_Frontend.Mvc.ViewModels
@model List<TiendaProductoViewModel>
@{
    Layout = "_LayoutTienda";
    ViewData["Title"] = "Catálogo";
    string? buscar      = ViewBag.Buscar;
    int?    categoriaId = ViewBag.CategoriaId;
    var categorias = ViewBag.Categorias as List<TiendaCategoriaViewModel> ?? new List<TiendaCategoriaViewModel>();
    var grupos     = ViewBag.Grupos    as Dictionary<TiendaCategoriaViewModel, List<TiendaProductoViewModel>>
                     ?? new Dictionary<TiendaCategoriaViewModel, List<TiendaProductoViewModel>>();
}

<!-- Breadcrumb -->
<div class="tienda-breadcrumb">
    <div class="container">
        <nav aria-label="breadcrumb">
            <ol class="breadcrumb mb-0">
                <li class="breadcrumb-item"><a asp-controller="Tienda" asp-action="Index" data-i18n="common.home">Inicio</a></li>
                <li class="breadcrumb-item active" data-i18n="catalog.breadcrumb">Catálogo</li>
            </ol>
        </nav>
    </div>
</div>

<section class="py-5">
    <div class="container">

        <!-- Cabecera -->
        <div class="d-flex flex-column flex-md-row justify-content-between align-items-start align-items-md-center mb-4 gap-3">
            <div>
                <h2 class="section-title mb-1" data-i18n="catalog.title">Catálogo de Productos</h2>
                <p class="text-muted mb-0">@Model.Count <span data-i18n="catalog.products_available">producto(s) disponible(s)</span></p>
            </div>
            <form asp-action="Catalogo" method="get" class="d-flex gap-2 w-100 w-md-auto" style="max-width:400px;">
                @if (categoriaId.HasValue)
                {
                    <input type="hidden" name="categoriaId" value="@categoriaId" />
                }
                <input type="text" name="buscar" value="@buscar"
                       class="form-control tienda-search-bar"
                       data-i18n-placeholder="catalog.search_placeholder"
                       placeholder="Buscar productos..." />
                <button type="submit" class="btn btn-sm"
                        style="background:var(--tienda-primary);color:#fff;white-space:nowrap;">
                    <i class="bi bi-search"></i>
                </button>
            </form>
        </div>

        <!-- Filtros de categoría -->
        @if (categorias.Any())
        {
            <div class="mb-5">
                <div class="d-flex flex-wrap gap-2 align-items-center">
                    <span class="text-muted small fw-semibold me-1">
                        <i class="bi bi-tag me-1"></i><span data-i18n="catalog.categories_label">Categorías:</span>
                    </span>
                    <a asp-action="Catalogo" asp-route-buscar="@buscar"
                       class="badge rounded-pill text-decoration-none"
                       style="padding:.45rem 1rem;font-size:.82rem;
                              @(categoriaId == null
                                ? "background:var(--tienda-primary);color:#fff;"
                                : "background:#f0f0f0;color:#444;")">
                        <span data-i18n="catalog.all">Todas</span>
                    </a>
                    @foreach (var cat in categorias)
                    {
                        <a asp-action="Catalogo"
                           asp-route-buscar="@buscar"
                           asp-route-categoriaId="@cat.Id"
                           class="badge rounded-pill text-decoration-none"
                           style="padding:.45rem 1rem;font-size:.82rem;
                                  @(categoriaId == cat.Id
                                    ? "background:var(--tienda-primary);color:#fff;"
                                    : "background:#f0f0f0;color:#444;")">
                            @cat.Nombre
                        </a>
                    }
                </div>
            </div>
        }

        <!-- Productos agrupados por categoría -->
        @if (grupos.Any())
        {
            foreach (var grupo in grupos)
            {
                var cat   = grupo.Key;
                var prods = grupo.Value;

                <div class="mb-5">
                    <!-- Encabezado de categoría -->
                    <div class="d-flex align-items-center gap-3 mb-3 pb-2"
                         style="border-bottom:2px solid var(--tienda-primary);">
                        <div class="rounded-circle d-flex align-items-center justify-content-center"
                             style="width:36px;height:36px;background:var(--tienda-primary);flex-shrink:0;">
                            <i class="bi bi-tag-fill text-white" style="font-size:.85rem;"></i>
                        </div>
                        <div>
                            <h4 class="mb-0 fw-bold" style="color:var(--tienda-primary);">@cat.Nombre</h4>
                            @if (!string.IsNullOrWhiteSpace(cat.Descripcion))
                            {
                                <small class="text-muted">@cat.Descripcion</small>
                            }
                        </div>
                        <span class="ms-auto badge rounded-pill text-muted"
                              style="background:#f5f5f5;font-size:.78rem;">
                            @prods.Count <span data-i18n="catalog.products_count">producto(s)</span>
                        </span>
                    </div>

                    <!-- Grid de productos de esta categoría -->
                    <div class="row g-4">
                        @foreach (var p in prods)
                        {
                            <div class="col-xl-3 col-lg-4 col-md-6 col-12">
                                <div class="card producto-card h-100">
                                    <div class="producto-img-wrapper" style="height:200px;overflow:hidden;background:#f5f5f5;display:flex;align-items:center;justify-content:center;">
                                        @if (!string.IsNullOrEmpty(p.ImagenUrl))
                                        {
                                            <img src="@p.ImagenUrl" alt="@p.Nombre"
                                                 style="width:100%;height:100%;object-fit:cover;"
                                                 onerror="this.style.display='none';this.nextElementSibling.style.display='flex';" />
                                            <div style="display:none;width:100%;height:100%;align-items:center;justify-content:center;color:#ccc;font-size:2.5rem;">
                                                <i class="bi bi-image"></i>
                                            </div>
                                        }
                                        else
                                        {
                                            <i class="bi bi-image" style="font-size:2.5rem;color:#ccc;"></i>
                                        }
                                    </div>
                                    <div class="card-body d-flex flex-column">
                                        @if (p.TienePromocion)
                                        {
                                            <span class="badge-promo mb-2 align-self-start" data-i18n="home.sale_badge">Oferta</span>
                                        }
                                        <h6 class="card-title mb-1 fw-bold">@p.Nombre</h6>
                                        @if (!string.IsNullOrWhiteSpace(p.Descripcion))
                                        {
                                            <p class="text-muted small mb-1"
                                               style="display:-webkit-box;-webkit-line-clamp:2;-webkit-box-orient:vertical;overflow:hidden;">
                                                @p.Descripcion
                                            </p>
                                        }
                                        @if (!string.IsNullOrWhiteSpace(p.Sku))
                                        {
                                            <p class="text-muted mb-1" style="font-size:.75rem;">SKU: @p.Sku</p>
                                        }
                                        <div class="mt-auto d-flex justify-content-between align-items-center pt-2">
                                            <div>
                                                @if (p.TienePromocion && p.PrecioConDescuento.HasValue)
                                                {
                                                    <div class="text-muted small text-decoration-line-through">
                                                        Q @p.Precio.ToString("N2")
                                                    </div>
                                                    <span class="producto-precio fw-bold"
                                                          style="color:var(--tienda-accent);">
                                                        Q @p.PrecioConDescuento.Value.ToString("N2")
                                                    </span>
                                                }
                                                else
                                                {
                                                    <span class="producto-precio fw-bold">
                                                        Q @p.Precio.ToString("N2")
                                                    </span>
                                                }
                                            </div>
                                            <a asp-controller="Tienda" asp-action="Detalle" asp-route-id="@p.Id"
                                               class="btn-tienda" style="padding:7px 16px;font-size:.82rem;" data-i18n="catalog.see_more">
                                                Ver más
                                            </a>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        }
                    </div>
                </div>
            }
        }
        else
        {
            <div class="empty-state text-center py-5">
                <i class="bi bi-box2 d-block fs-1 text-muted"></i>
                <p class="mt-3 text-muted">
                    @if (!string.IsNullOrWhiteSpace(buscar))
                    {
                        <span><span data-i18n="catalog.no_results_for">No se encontraron productos para</span> "<strong>@buscar</strong>".</span>
                    }
                    else
                    {
                        <span data-i18n="catalog.no_products">No hay productos disponibles en este momento.</span>
                    }
                </p>
                <a asp-controller="Tienda" asp-action="Index" class="btn-tienda mt-3" data-i18n="catalog.back_home">Volver al inicio</a>
            </div>
        }

    </div>
</section>

<script>
    // Búsqueda en tiempo real sobre los productos ya renderizados
    const searchInput = document.querySelector('input[name="buscar"]');
    if (searchInput) {
        searchInput.addEventListener('input', function () {
            const q = this.value.toLowerCase().trim();
            document.querySelectorAll('.col-xl-3, .col-lg-4, .col-md-6').forEach(col => {
                const text = col.innerText.toLowerCase();
                col.style.display = q === '' || text.includes(q) ? '' : 'none';
            });
        });
    }
</script>

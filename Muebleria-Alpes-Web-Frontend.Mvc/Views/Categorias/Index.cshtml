@using Muebleria_Alpes_Web_Frontend.Mvc.ViewModels.Productos
@model List<CategoriaViewModel>

@{
    ViewData["Title"] = "Categorías";
}

<div class="page-header">
    <div class="page-title-box">
        <div class="page-icon">
            <i class="bi bi-tag"></i>
        </div>
        <div>
            <h1>Categorías</h1>
            <p>Gestión de categorías de productos</p>
        </div>
    </div>

    <div class="page-actions">
        <input type="text" id="buscarCategoria" class="form-control search-input" placeholder="Buscar..." />
        <button class="btn btn-primary btn-main" data-bs-toggle="modal" data-bs-target="#modalCrearCategoria">
            <i class="bi bi-plus-lg"></i> Nueva Categoría
        </button>
    </div>
</div>

@if (TempData["Success"] != null)
{
    <div class="alert alert-success">@TempData["Success"]</div>
}

@if (TempData["Error"] != null)
{
    <div class="alert alert-danger">@TempData["Error"]</div>
}

<div class="record-count">
    @Model.Count registros
</div>

<div class="erp-card">
    <div class="table-responsive">
        <table class="table erp-table" id="tablaCategorias">
            <thead>
                <tr>
                    <th>Código</th>
                    <th>Nombre</th>
                    <th>Descripción</th>
                    <th class="text-end">Acciones</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var item in Model)
                {
                    <tr>
                        <td>
                            <span class="code-badge">@item.Codigo</span>
                        </td>

                        <td>
                            <div class="employee-cell">
                                <div class="employee-avatar">
                                    <i class="bi bi-tag"></i>
                                </div>
                                <div>
                                    <div class="employee-name">@item.Nombre</div>
                                </div>
                            </div>
                        </td>

                        <td>
                            <span class="employee-subtitle">@(item.Descripcion ?? "-")</span>
                        </td>

                        <td class="text-end">
                            <div class="action-group">
                                <button class="btn-icon btn-edit"
                                        type="button"
                                        data-bs-toggle="modal"
                                        data-bs-target="#modalEditarCategoria-@item.Id"
                                        title="Editar">
                                    <i class="bi bi-pencil"></i>
                                </button>

                                <form asp-controller="Categorias"
                                      asp-action="Eliminar"
                                      asp-route-id="@item.Id"
                                      method="post"
                                      class="d-inline"
                                      onsubmit="return confirm('¿Eliminar esta categoría?');">
                                    <button type="submit" class="btn-icon btn-delete" title="Eliminar">
                                        <i class="bi bi-trash"></i>
                                    </button>
                                </form>
                            </div>
                        </td>
                    </tr>

                    @await Html.PartialAsync("_EditarCategoriaModal", item)
                }
            </tbody>
        </table>
    </div>
</div>

@await Html.PartialAsync("_CrearCategoriaModal", new CrearCategoriaViewModel())

@section Scripts {
    <script>
        document.addEventListener('DOMContentLoaded', function () {
            const buscar = document.getElementById('buscarCategoria');
            if (buscar) {
                buscar.addEventListener('keyup', function () {
                    const val = this.value.toLowerCase();
                    document.querySelectorAll('#tablaCategorias tbody tr').forEach(row => {
                        row.style.display = row.textContent.toLowerCase().includes(val) ? '' : 'none';
                    });
                });
            }
        });
    </script>
}

@model List<Muebleria_Alpes_Web_Frontend.Mvc.ViewModels.PermisoAlvaroViewModel>
@{ ViewData["Title"] = "Permisos"; var estadoActual = ViewBag.Estado as string ?? "ACTIVO"; }
<div class="crud-page">
  <div class="d-flex justify-content-between align-items-center mb-4"><div><h1>Permisos</h1><p class="text-muted">Mantenimiento de permisos del sistema.</p></div><button class="btn btn-danger" data-bs-toggle="modal" data-bs-target="#crearPermiso">Nuevo permiso</button></div>
  @if (TempData["Success"] is not null){<div class="alert alert-success">@TempData["Success"]</div>} @if (TempData["Error"] is not null){<div class="alert alert-danger">@TempData["Error"]</div>}
  <div class="card border-0 shadow-sm rounded-4 mb-3"><div class="card-body"><a class="btn btn-sm @(estadoActual=="ACTIVO"?"btn-danger":"btn-outline-danger")" asp-route-estado="ACTIVO">Activos</a> <a class="btn btn-sm @(estadoActual=="INACTIVO"?"btn-secondary":"btn-outline-secondary")" asp-route-estado="INACTIVO">Inactivos</a></div></div>
  <div class="card border-0 shadow-sm rounded-4"><div class="table-responsive"><table class="table align-middle mb-0"><thead class="table-light"><tr><th>Código</th><th>Nombre</th><th>Descripción</th><th>Estado</th><th class="text-end">Acciones</th></tr></thead><tbody>
  @foreach(var p in Model){<tr><td>@p.Codigo</td><td class="fw-semibold">@p.Nombre</td><td>@p.Descripcion</td><td><span class="badge @(p.Estado=="ACTIVO"?"bg-success":"bg-secondary")">@p.Estado</span></td><td class="text-end"><button class="btn btn-sm btn-outline-primary" data-bs-toggle="modal" data-bs-target="#editarPermiso" data-id="@p.PermisoId" data-nombre="@p.Nombre" data-descripcion="@p.Descripcion" data-estado="@p.Estado">Editar</button> @if(p.Estado=="ACTIVO"){<form class="d-inline" asp-action="InactivarPermiso" method="post"><input type="hidden" name="permisoId" value="@p.PermisoId"/><button class="btn btn-sm btn-outline-danger">Inactivar</button></form>}</td></tr>}
  </tbody></table></div></div>
</div>
<div class="modal fade" id="crearPermiso"><div class="modal-dialog"><form class="modal-content" asp-action="CrearPermiso" method="post"><div class="modal-header"><h5>Nuevo permiso</h5><button type="button" class="btn-close" data-bs-dismiss="modal"></button></div><div class="modal-body"><input class="form-control mb-3" name="nombre" placeholder="Nombre" required/><textarea class="form-control mb-3" name="descripcion" placeholder="Descripción"></textarea><select class="form-select" name="estado"><option>ACTIVO</option><option>INACTIVO</option></select></div><div class="modal-footer"><button class="btn btn-danger">Crear</button></div></form></div></div>
<div class="modal fade" id="editarPermiso"><div class="modal-dialog"><form class="modal-content" asp-action="ActualizarPermiso" method="post"><div class="modal-header"><h5>Editar permiso</h5><button type="button" class="btn-close" data-bs-dismiss="modal"></button></div><div class="modal-body"><input type="hidden" name="permisoId" id="permisoId"/><input class="form-control mb-3" name="nombre" id="permisoNombre" required/><textarea class="form-control mb-3" name="descripcion" id="permisoDesc"></textarea><select class="form-select" name="estado" id="permisoEstado"><option>ACTIVO</option><option>INACTIVO</option></select></div><div class="modal-footer"><button class="btn btn-danger">Guardar</button></div></form></div></div>
@section Scripts{<script>document.getElementById('editarPermiso')?.addEventListener('show.bs.modal',e=>{let b=e.relatedTarget; permisoId.value=b.dataset.id; permisoNombre.value=b.dataset.nombre; permisoDesc.value=b.dataset.descripcion||''; permisoEstado.value=b.dataset.estado;});</script>}

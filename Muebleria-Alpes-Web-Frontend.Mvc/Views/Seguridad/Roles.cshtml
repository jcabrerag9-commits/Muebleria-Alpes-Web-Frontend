@model List<Muebleria_Alpes_Web_Frontend.Mvc.ViewModels.RolAlvaroViewModel>
@{ ViewData["Title"] = "Roles"; var estadoActual = ViewBag.Estado as string ?? "ACTIVO"; }
<div class="crud-page">
  <div class="d-flex justify-content-between align-items-center mb-4"><div><h1>Roles</h1><p class="text-muted">Mantenimiento de roles de seguridad.</p></div><button class="btn btn-danger" data-bs-toggle="modal" data-bs-target="#crearRol">Nuevo rol</button></div>
  @if (TempData["Success"] is not null){<div class="alert alert-success">@TempData["Success"]</div>} @if (TempData["Error"] is not null){<div class="alert alert-danger">@TempData["Error"]</div>}
  <div class="card border-0 shadow-sm rounded-4 mb-3"><div class="card-body"><a class="btn btn-sm @(estadoActual=="ACTIVO"?"btn-danger":"btn-outline-danger")" asp-route-estado="ACTIVO">Activos</a> <a class="btn btn-sm @(estadoActual=="INACTIVO"?"btn-secondary":"btn-outline-secondary")" asp-route-estado="INACTIVO">Inactivos</a></div></div>
  <div class="card border-0 shadow-sm rounded-4"><div class="table-responsive"><table class="table align-middle mb-0"><thead class="table-light"><tr><th>Código</th><th>Nombre</th><th>Descripción</th><th>Estado</th><th class="text-end">Acciones</th></tr></thead><tbody>
  @foreach(var r in Model){<tr><td>@r.Codigo</td><td class="fw-semibold">@r.Nombre</td><td>@r.Descripcion</td><td><span class="badge @(r.Estado=="ACTIVO"?"bg-success":"bg-secondary")">@r.Estado</span></td><td class="text-end"><button class="btn btn-sm btn-outline-primary" data-bs-toggle="modal" data-bs-target="#editarRol" data-id="@r.RolId" data-nombre="@r.Nombre" data-descripcion="@r.Descripcion" data-estado="@r.Estado">Editar</button> @if(r.Estado=="ACTIVO"){<form class="d-inline" asp-action="InactivarRol" method="post"><input type="hidden" name="rolId" value="@r.RolId"/><button class="btn btn-sm btn-outline-danger">Inactivar</button></form>}</td></tr>}
  </tbody></table></div></div>
</div>
<div class="modal fade" id="crearRol"><div class="modal-dialog"><form class="modal-content" asp-action="CrearRol" method="post"><div class="modal-header"><h5>Nuevo rol</h5><button type="button" class="btn-close" data-bs-dismiss="modal"></button></div><div class="modal-body"><input class="form-control mb-3" name="nombre" placeholder="Nombre" required/><textarea class="form-control mb-3" name="descripcion" placeholder="Descripción"></textarea><select class="form-select" name="estado"><option>ACTIVO</option><option>INACTIVO</option></select></div><div class="modal-footer"><button class="btn btn-danger">Crear</button></div></form></div></div>
<div class="modal fade" id="editarRol"><div class="modal-dialog"><form class="modal-content" asp-action="ActualizarRol" method="post"><div class="modal-header"><h5>Editar rol</h5><button type="button" class="btn-close" data-bs-dismiss="modal"></button></div><div class="modal-body"><input type="hidden" name="rolId" id="rolId"/><input class="form-control mb-3" name="nombre" id="rolNombre" required/><textarea class="form-control mb-3" name="descripcion" id="rolDesc"></textarea><select class="form-select" name="estado" id="rolEstado"><option>ACTIVO</option><option>INACTIVO</option></select></div><div class="modal-footer"><button class="btn btn-danger">Guardar</button></div></form></div></div>
@section Scripts{<script>document.getElementById('editarRol')?.addEventListener('show.bs.modal',e=>{let b=e.relatedTarget; rolId.value=b.dataset.id; rolNombre.value=b.dataset.nombre; rolDesc.value=b.dataset.descripcion||''; rolEstado.value=b.dataset.estado;});</script>}

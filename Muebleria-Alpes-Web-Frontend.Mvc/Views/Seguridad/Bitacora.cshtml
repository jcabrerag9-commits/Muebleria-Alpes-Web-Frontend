@{ ViewData["Title"] = "Bitácora"; }
<div class="crud-page">
  <h1>Bitácora de acceso</h1><p class="text-muted">Registro manual de eventos de auditoría para pruebas/control.</p>
  @if (TempData["Success"] is not null){<div class="alert alert-success">@TempData["Success"]</div>} @if (TempData["Error"] is not null){<div class="alert alert-danger">@TempData["Error"]</div>}
  <div class="card border-0 shadow-sm rounded-4"><div class="card-body"><form asp-action="RegistrarBitacora" method="post" class="row g-3">
    <div class="col-md-3"><label class="form-label">Usuario ID</label><input class="form-control" type="number" name="usuarioId" required/></div>
    <div class="col-md-3"><label class="form-label">Username</label><input class="form-control" name="username" required/></div>
    <div class="col-md-3"><label class="form-label">Resultado</label><select class="form-select" name="resultado"><option>EXITOSO</option><option>FALLIDO</option></select></div>
    <div class="col-12"><label class="form-label">Detalle</label><textarea class="form-control" name="detalle" rows="3"></textarea></div>
    <div class="col-12"><button class="btn btn-danger">Registrar bitácora</button></div>
  </form></div></div>
</div>

@model List<Muebleria_Alpes_Web_Frontend.Mvc.ViewModels.UsuarioViewModel>
@{
    ViewData["Title"] = "Usuarios";
    var estadoActual = ViewBag.Estado as string ?? "ACTIVO";
}

<div class="crud-page">
    <div class="crud-header d-flex justify-content-between align-items-center mb-4">
        <div>
            <h1 class="mb-1">Usuarios</h1>
            <p class="text-muted mb-0">Mantenimiento de usuarios del sistema.</p>
        </div>
        <button class="btn btn-danger" data-bs-toggle="modal" data-bs-target="#crearUsuarioModal"><i class="bi bi-plus-lg"></i> Nuevo usuario</button>
    </div>

    @if (TempData["Success"] is not null) { <div class="alert alert-success">@TempData["Success"]</div> }
    @if (TempData["Error"] is not null) { <div class="alert alert-danger">@TempData["Error"]</div> }

    <div class="card border-0 shadow-sm rounded-4 mb-3">
        <div class="card-body d-flex gap-2 align-items-center">
            <span class="fw-semibold">Estado:</span>
            <a class="btn btn-sm @(estadoActual=="ACTIVO"?"btn-danger":"btn-outline-danger")" asp-action="Usuarios" asp-route-estado="ACTIVO">Activos</a>
            <a class="btn btn-sm @(estadoActual=="INACTIVO"?"btn-secondary":"btn-outline-secondary")" asp-action="Usuarios" asp-route-estado="INACTIVO">Inactivos</a>
        </div>
    </div>

    <div class="card border-0 shadow-sm rounded-4">
        <div class="table-responsive">
            <table class="table align-middle mb-0">
                <thead class="table-light"><tr><th>Código</th><th>Usuario</th><th>Estado</th><th class="text-end">Acciones</th></tr></thead>
                <tbody>
                @foreach (var u in Model)
                {
                    <tr>
                        <td>@u.Codigo</td>
                        <td class="fw-semibold">@u.Username</td>
                        <td><span class="badge @(u.Estado=="ACTIVO"?"bg-success":"bg-secondary")">@u.Estado</span></td>
                        <td class="text-end">
                            <button class="btn btn-sm btn-outline-primary" data-bs-toggle="modal" data-bs-target="#editarUsuarioModal" data-id="@u.UsuarioId" data-username="@u.Username" data-estado="@u.Estado">Editar</button>
                            <button class="btn btn-sm btn-outline-warning" data-bs-toggle="modal" data-bs-target="#passwordModal" data-id="@u.UsuarioId">Contraseña</button>
                            @if (u.Estado == "ACTIVO")
                            {
                                <form class="d-inline" asp-action="Bloquear" method="post"><input type="hidden" name="usuarioId" value="@u.UsuarioId"/><button class="btn btn-sm btn-outline-dark">Bloquear</button></form>
                                <form class="d-inline" asp-action="InactivarUsuario" method="post"><input type="hidden" name="usuarioId" value="@u.UsuarioId"/><button class="btn btn-sm btn-outline-danger">Inactivar</button></form>
                            }
                            else
                            {
                                <form class="d-inline" asp-action="Desbloquear" method="post"><input type="hidden" name="usuarioId" value="@u.UsuarioId"/><button class="btn btn-sm btn-outline-success">Desbloquear</button></form>
                            }
                        </td>
                    </tr>
                }
                </tbody>
            </table>
        </div>
    </div>
</div>

<div class="modal fade" id="crearUsuarioModal" tabindex="-1"><div class="modal-dialog"><form class="modal-content" asp-action="CrearUsuario" method="post">
    <div class="modal-header"><h5 class="modal-title">Nuevo usuario</h5><button type="button" class="btn-close" data-bs-dismiss="modal"></button></div>
    <div class="modal-body">
        <label class="form-label">Usuario</label><input class="form-control mb-3" name="username" required />
        <label class="form-label">Contraseña</label><input class="form-control mb-3" type="password" name="passwordPlano" required />
        <label class="form-label">Estado</label><select class="form-select" name="estado"><option>ACTIVO</option><option>INACTIVO</option></select>
    </div>
    <div class="modal-footer"><button class="btn btn-secondary" type="button" data-bs-dismiss="modal">Cancelar</button><button class="btn btn-danger">Crear</button></div>
</form></div></div>

<div class="modal fade" id="editarUsuarioModal" tabindex="-1"><div class="modal-dialog"><form class="modal-content" asp-action="ActualizarUsuario" method="post">
    <div class="modal-header"><h5 class="modal-title">Editar usuario</h5><button type="button" class="btn-close" data-bs-dismiss="modal"></button></div>
    <div class="modal-body">
        <input type="hidden" name="usuarioId" id="editUsuarioId" />
        <label class="form-label">Usuario</label><input class="form-control mb-3" name="username" id="editUsername" required />
        <label class="form-label">Estado</label><select class="form-select" name="estado" id="editEstado"><option>ACTIVO</option><option>INACTIVO</option></select>
    </div>
    <div class="modal-footer"><button class="btn btn-secondary" type="button" data-bs-dismiss="modal">Cancelar</button><button class="btn btn-danger">Guardar</button></div>
</form></div></div>

<div class="modal fade" id="passwordModal" tabindex="-1"><div class="modal-dialog"><form class="modal-content" asp-action="CambiarPassword" method="post">
    <div class="modal-header"><h5 class="modal-title">Cambiar contraseña</h5><button type="button" class="btn-close" data-bs-dismiss="modal"></button></div>
    <div class="modal-body"><input type="hidden" name="usuarioId" id="passUsuarioId"/><label class="form-label">Nueva contraseña</label><input class="form-control" type="password" name="passwordPlano" required /></div>
    <div class="modal-footer"><button class="btn btn-secondary" type="button" data-bs-dismiss="modal">Cancelar</button><button class="btn btn-danger">Actualizar</button></div>
</form></div></div>

@section Scripts {
<script>
document.getElementById('editarUsuarioModal')?.addEventListener('show.bs.modal', e => {
  const b=e.relatedTarget; document.getElementById('editUsuarioId').value=b.dataset.id; document.getElementById('editUsername').value=b.dataset.username; document.getElementById('editEstado').value=b.dataset.estado;
});
document.getElementById('passwordModal')?.addEventListener('show.bs.modal', e => { document.getElementById('passUsuarioId').value=e.relatedTarget.dataset.id; });
</script>
}

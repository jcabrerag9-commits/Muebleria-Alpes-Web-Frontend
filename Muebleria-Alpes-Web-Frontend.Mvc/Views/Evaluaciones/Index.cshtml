@using Muebleria_Alpes_Web_Frontend.Mvc.ViewModels.RecursosHumanos
@model List<EvaluacionViewModel>

@{
    ViewData["Title"] = "Evaluaciones";
}

<div class="page-header">
    <div class="page-title-box">
        <div class="page-icon">
            <i class="bi bi-star"></i>
        </div>
        <div>
            <h1>Evaluaciones</h1>
            <p>Evaluaciones de desempeño del personal</p>
        </div>
    </div>

    <div class="page-actions">
        <button class="btn btn-primary btn-main" data-bs-toggle="modal" data-bs-target="#modalCrearEvaluacion">
            <i class="bi bi-plus-lg"></i> Nueva Evaluación
        </button>
    </div>
</div>

@if (TempData["Success"] != null)
{
    <div class="alert alert-success">@TempData["Success"]</div>
}

@if (TempData["Error"] != null)
{
    <div class="alert alert-danger">@TempData["Error"]</div>
}

<div class="erp-card mb-3">
    <form asp-controller="Evaluaciones" asp-action="Index" method="get" class="row g-2 align-items-end p-3">
        <div class="col-md-8">
            <label class="form-label">Empleado ID</label>
            <input type="number" name="empleadoId" class="form-control" value="@ViewBag.EmpleadoId" placeholder="Filtrar por ID de empleado" />
        </div>
        <div class="col-md-4">
            <button type="submit" class="btn btn-primary w-100">
                <i class="bi bi-search"></i> Filtrar
            </button>
        </div>
    </form>
</div>

<div class="record-count">
    @Model.Count registros
</div>

<div class="erp-card">
    <div class="table-responsive">
        <table class="table erp-table">
            <thead>
                <tr>
                    <th>Empleado</th>
                    <th>Fecha</th>
                    <th>Calificación</th>
                    <th>Comentarios</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var e in Model)
                {
                    <tr>
                        <td>
                            <div class="employee-cell">
                                <div class="employee-avatar">
                                    @(string.IsNullOrWhiteSpace(e.NombreEmpleado) ? e.EmpleadoId.ToString() :
                                        string.Join("", (e.NombreEmpleado ?? "NA")
                                            .Split(" ", StringSplitOptions.RemoveEmptyEntries)
                                            .Take(2)
                                            .Select(x => x[0])).ToUpper())
                                </div>
                                <div class="employee-name">@(e.NombreEmpleado ?? $"Empleado #{e.EmpleadoId}")</div>
                            </div>
                        </td>
                        <td>@e.FechaEvaluacion.ToString("dd/MM/yyyy")</td>
                        <td>
                            @{
                                var calBadge = e.Calificacion >= 80 ? "status-badge status-active"
                                    : e.Calificacion >= 60 ? "status-badge status-warning"
                                    : "status-badge status-inactive";
                            }
                            <span class="@calBadge">@e.Calificacion / 100</span>
                        </td>
                        <td>@(e.Comentarios ?? "—")</td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>

@await Html.PartialAsync("_CrearEvaluacionModal", new CrearEvaluacionViewModel())

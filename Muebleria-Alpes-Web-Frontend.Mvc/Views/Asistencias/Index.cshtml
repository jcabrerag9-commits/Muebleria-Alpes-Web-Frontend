@using Muebleria_Alpes_Web_Frontend.Mvc.ViewModels.RecursosHumanos
@model List<AsistenciaViewModel>

@{
    ViewData["Title"] = "Asistencias";
}

<div class="page-header">
    <div class="page-title-box">
        <div class="page-icon">
            <i class="bi bi-calendar-check"></i>
        </div>
        <div>
            <h1>Asistencias</h1>
            <p>Control de asistencia del personal</p>
        </div>
    </div>

    <div class="page-actions">
        <button class="btn btn-primary btn-main" data-bs-toggle="modal" data-bs-target="#modalRegistrarAsistencia">
            <i class="bi bi-plus-lg"></i> Registrar Asistencia
        </button>
    </div>
</div>

@if (TempData["Success"] != null)
{
    <div class="alert alert-success">@TempData["Success"]</div>
}

@if (TempData["Error"] != null)
{
    <div class="alert alert-danger">@TempData["Error"]</div>
}

<div class="erp-card mb-3">
    <form asp-controller="Asistencias" asp-action="Index" method="get" class="row g-2 align-items-end p-3">
        <div class="col-md-3">
            <label class="form-label">Empleado ID</label>
            <input type="number" name="empleadoId" class="form-control" value="@ViewBag.EmpleadoId" placeholder="ID del empleado" />
        </div>
        <div class="col-md-3">
            <label class="form-label">Fecha Inicio</label>
            <input type="date" name="fechaInicio" class="form-control" value="@ViewBag.FechaInicio" />
        </div>
        <div class="col-md-3">
            <label class="form-label">Fecha Fin</label>
            <input type="date" name="fechaFin" class="form-control" value="@ViewBag.FechaFin" />
        </div>
        <div class="col-md-3">
            <button type="submit" class="btn btn-primary w-100">
                <i class="bi bi-search"></i> Filtrar
            </button>
        </div>
    </form>
</div>

<div class="record-count">
    @Model.Count registros
</div>

<div class="erp-card">
    <div class="table-responsive">
        <table class="table erp-table">
            <thead>
                <tr>
                    <th>Empleado ID</th>
                    <th>Fecha</th>
                    <th>Hora Entrada</th>
                    <th>Hora Salida</th>
                    <th>Estado</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var a in Model)
                {
                    <tr>
                        <td>@a.EmpleadoId</td>
                        <td>@a.Fecha.ToString("dd/MM/yyyy")</td>
                        <td>@(a.HoraEntrada ?? "—")</td>
                        <td>@(a.HoraSalida ?? "—")</td>
                        <td>
                            @{
                                var badgeClass = a.Estado switch
                                {
                                    "PRESENTE" => "status-badge status-active",
                                    "AUSENTE" => "status-badge status-inactive",
                                    "TARDANZA" => "status-badge status-warning",
                                    _ => "status-badge status-inactive"
                                };
                            }
                            <span class="@badgeClass">@a.Estado</span>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>

@await Html.PartialAsync("_RegistrarAsistenciaModal", new CrearAsistenciaViewModel())

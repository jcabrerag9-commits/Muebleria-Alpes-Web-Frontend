@model Muebleria_Alpes_Web_Frontend.Mvc.ViewModels.Promociones.PromocionUpdateViewModel
@{
    ViewData["Title"] = "Editar Promoción";
    var promoId = ViewBag.PromocionId;
}

<div class="page-header mb-4">
    <a asp-action="Index" class="btn-back"><i class="bi bi-arrow-left"></i> Volver</a>
    <h2 class="page-title mt-2">Editar Promoción</h2>
    <p class="page-subtitle">Código: <strong>@ViewBag.Codigo</strong> — Tipo: <strong>@ViewBag.Tipo</strong></p>
</div>

@if (TempData["Error"] != null)
{
    <div class="alert alert-danger alert-dismissible fade show">
        <i class="bi bi-exclamation-circle me-2"></i>@TempData["Error"]
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
}

<div class="alpes-card" style="max-width:720px">
    <form asp-action="Editar" asp-route-id="@promoId" method="post">
        @Html.AntiForgeryToken()

        <div class="row g-3">
            <div class="col-12">
                <label class="form-label-alpes">Nombre</label>
                <input asp-for="PrmNombre" class="form-control-alpes" />
            </div>

            <div class="col-12">
                <label class="form-label-alpes">Descripción</label>
                <textarea asp-for="PrmDescripcion" class="form-control-alpes" rows="2"></textarea>
            </div>

            <div class="col-md-6">
                <label class="form-label-alpes">Valor</label>
                <input asp-for="PrmValor" type="number" step="0.01" class="form-control-alpes" />
            </div>

            <div class="col-md-6">
                <label class="form-label-alpes">Estado</label>
                <select asp-for="PrmEstado" class="form-control-alpes">
                    <option value="ACTIVO">Activo</option>
                    <option value="INACTIVO">Inactivo</option>
                    <option value="EXPIRADO">Expirado</option>
                </select>
            </div>

            <div class="col-md-6">
                <label class="form-label-alpes">Fecha inicio</label>
                <input asp-for="PrmFechaInicio" type="date" class="form-control-alpes" />
            </div>

            <div class="col-md-6">
                <label class="form-label-alpes">Fecha fin</label>
                <input asp-for="PrmFechaFin" type="date" class="form-control-alpes" />
            </div>
        </div>

        <div class="d-flex gap-2 mt-4">
            <button type="submit" class="btn btn-primary-alpes">
                <i class="bi bi-check-lg me-1"></i> Guardar cambios
            </button>
            <a asp-action="Index" class="btn btn-outline-secondary">Cancelar</a>
        </div>
    </form>
</div>

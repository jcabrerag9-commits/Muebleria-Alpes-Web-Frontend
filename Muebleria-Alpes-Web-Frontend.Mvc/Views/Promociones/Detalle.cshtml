@model Muebleria_Alpes_Web_Frontend.Mvc.ViewModels.Promociones.PromocionViewModel
@{
    ViewData["Title"] = "Detalle Promoción";
}

<div class="page-header d-flex align-items-center justify-content-between mb-4">
    <div>
        <a asp-action="Index" class="btn-back"><i class="bi bi-arrow-left"></i> Volver</a>
        <h2 class="page-title mt-2">@Model.PrmNombre</h2>
        <p class="page-subtitle">Código: <strong>@Model.PrmCodigo</strong></p>
    </div>
    <div class="d-flex gap-2">
        <a asp-action="Editar" asp-route-id="@Model.PrmPromocion" class="btn btn-outline-secondary btn-sm">
            <i class="bi bi-pencil me-1"></i> Editar
        </a>
    </div>
</div>

@if (TempData["Success"] != null)
{
    <div class="alert alert-success alert-dismissible fade show">
        <i class="bi bi-check-circle me-2"></i>@TempData["Success"]
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
}

<div class="row g-4">
    <div class="col-md-8">
        <div class="alpes-card">
            <h5 class="card-section-title">Información general</h5>
            <div class="detail-grid">
                <div class="detail-item">
                    <span class="detail-label">Tipo</span>
                    <span class="promo-badge">@Model.TipoDisplay</span>
                </div>
                <div class="detail-item">
                    <span class="detail-label">Estado</span>
                    @{
                        var cls = Model.PrmEstado switch {
                            "ACTIVO"   => "badge-estado-activo",
                            "INACTIVO" => "badge-estado-inactivo",
                            _          => "badge-estado-default"
                        };
                    }
                    <span class="badge-estado @cls">@Model.PrmEstado</span>
                    @if (Model.EstaVigente)
                    {
                        <span class="badge bg-success-soft text-success ms-2">Vigente</span>
                    }
                </div>
                <div class="detail-item">
                    <span class="detail-label">Fecha inicio</span>
                    <span>@Model.PrmFechaInicio.ToString("dd/MM/yyyy")</span>
                </div>
                <div class="detail-item">
                    <span class="detail-label">Fecha fin</span>
                    <span>@Model.PrmFechaFin.ToString("dd/MM/yyyy")</span>
                </div>
                @if (!string.IsNullOrEmpty(Model.PrmDescripcion))
                {
                    <div class="detail-item col-span-2">
                        <span class="detail-label">Descripción</span>
                        <span>@Model.PrmDescripcion</span>
                    </div>
                }
            </div>
        </div>

        <div class="alpes-card mt-4">
            <h5 class="card-section-title">Productos asociados</h5>
            @if (!Model.Productos.Any())
            {
                <p class="text-muted small">No hay productos asociados a esta promoción.</p>
            }
            else
            {
                <table class="table alpes-table">
                    <thead>
                        <tr>
                            <th>ID Relación</th>
                            <th>Producto</th>
                            <th>Variante</th>
                            <th>Estado</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var p in Model.Productos)
                        {
                            <tr>
                                <td>@p.PpoPromocionProducto</td>
                                <td>@(p.ProProducto?.ToString() ?? "—")</td>
                                <td>@(p.PvaProductoVariante?.ToString() ?? "—")</td>
                                <td><span class="badge-estado badge-estado-activo">@p.PpoEstado</span></td>
                            </tr>
                        }
                    </tbody>
                </table>
            }
        </div>
    </div>

    <div class="col-md-4">
        <div class="alpes-card">
            <h5 class="card-section-title">Acciones</h5>
            <div class="d-grid gap-2">
                <a asp-action="Editar" asp-route-id="@Model.PrmPromocion" class="btn btn-primary-alpes">
                    <i class="bi bi-pencil me-1"></i> Editar promoción
                </a>
                <form asp-action="Eliminar" method="post"
                      onsubmit="return confirm('¿Eliminar esta promoción?')">
                    <input type="hidden" name="id" value="@Model.PrmPromocion" />
                    @Html.AntiForgeryToken()
                    <button type="submit" class="btn btn-danger w-100">
                        <i class="bi bi-trash me-1"></i> Eliminar
                    </button>
                </form>
            </div>
        </div>
    </div>
</div>

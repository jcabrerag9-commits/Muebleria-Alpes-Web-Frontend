@using Muebleria_Alpes_Web_Frontend.Mvc.ViewModels
@model CarritoViewModel
@{
    Layout = "_LayoutTienda";
    ViewData["Title"] = "Checkout";

    decimal subtotal = Model.Cabecera?.Subtotal ?? Model.Detalle.Sum(d => d.Subtotal);
    decimal impuestos = Math.Round(subtotal * 0.12m, 2);
    decimal total = subtotal + impuestos;
}

<!-- Breadcrumb -->
<div class="tienda-breadcrumb">
    <div class="container">
        <nav aria-label="breadcrumb">
            <ol class="breadcrumb mb-0">
                <li class="breadcrumb-item"><a asp-controller="Tienda" asp-action="Index">Inicio</a></li>
                <li class="breadcrumb-item"><a asp-controller="Carrito" asp-action="Index">Carrito</a></li>
                <li class="breadcrumb-item active">Checkout</li>
            </ol>
        </nav>
    </div>
</div>

<section class="py-5">
    <div class="container">
        <h2 class="section-title mb-4"><i class="bi bi-credit-card me-2"></i>Confirmar Pedido</h2>

        @if (TempData["Success"] != null)
        {
            <div class="alert alert-success alert-dismissible fade show" data-auto-dismiss role="alert">
                <i class="bi bi-check-circle me-2"></i>@TempData["Success"]
                <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
            </div>
        }
        @if (TempData["Error"] != null)
        {
            <div class="alert alert-danger alert-dismissible fade show" data-auto-dismiss role="alert">
                <i class="bi bi-exclamation-triangle me-2"></i>@TempData["Error"]
                <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
            </div>
        }

        @if (!Model.Detalle.Any())
        {
            <div class="empty-state">
                <i class="bi bi-cart-x d-block"></i>
                <p class="mt-3 fw-semibold">No hay productos en tu carrito.</p>
                <a asp-controller="Tienda" asp-action="Catalogo" class="btn-tienda mt-3">Ir al catálogo</a>
            </div>
        }
        else
        {
            <div class="row g-4">

                <!-- Customer Info (simplified) -->
                <div class="col-lg-7">
                    <div class="card border-0 shadow-sm mb-4" style="border-radius: 14px;">
                        <div class="card-body p-4">
                            <h5 class="fw-bold mb-3" style="color: var(--tienda-primary);">
                                <i class="bi bi-person me-2"></i>Datos del pedido
                            </h5>
                            <div class="alert alert-info" style="border-radius: 10px; font-size: 0.9rem;">
                                <i class="bi bi-info-circle me-2"></i>
                                Estás realizando el pedido como <strong>Cliente #1</strong>.
                                La autenticación completa estará disponible próximamente.
                            </div>
                        </div>
                    </div>

                    <!-- Items Summary -->
                    <div class="card border-0 shadow-sm" style="border-radius: 14px;">
                        <div class="card-body p-4">
                            <h5 class="fw-bold mb-3" style="color: var(--tienda-primary);">
                                <i class="bi bi-list-ul me-2"></i>Productos del pedido
                            </h5>
                            @foreach (var item in Model.Detalle)
                            {
                                <div class="d-flex justify-content-between align-items-center py-2 border-bottom">
                                    <div>
                                        <div class="fw-semibold">@item.ProductoNombre</div>
                                        <small class="text-muted">Cant: @item.Cantidad × Q @item.PrecioUnitario.ToString("N2")</small>
                                    </div>
                                    <div class="fw-bold">Q @item.Subtotal.ToString("N2")</div>
                                </div>
                            }
                        </div>
                    </div>
                </div>

                <!-- Order Summary + Confirm -->
                <div class="col-lg-5">
                    <div class="carrito-resumen">
                        <h5 class="fw-bold mb-4" style="color: var(--tienda-primary);">Resumen del pedido</h5>

                        <div class="d-flex justify-content-between mb-2">
                            <span class="text-muted">Subtotal</span>
                            <span>Q @subtotal.ToString("N2")</span>
                        </div>
                        <div class="d-flex justify-content-between mb-2">
                            <span class="text-muted">IVA (12%)</span>
                            <span>Q @impuestos.ToString("N2")</span>
                        </div>
                        <div class="d-flex justify-content-between mb-2">
                            <span class="text-muted">Envío</span>
                            <span class="text-success fw-semibold">Gratis</span>
                        </div>
                        <hr />
                        <div class="d-flex justify-content-between mb-4">
                            <span class="fw-bold fs-5">Total</span>
                            <span class="carrito-total">Q @total.ToString("N2")</span>
                        </div>

                        @if (Model.Cabecera != null)
                        {
                            <form asp-action="ConfirmarOrden" method="post">
                                @Html.AntiForgeryToken()
                                <input type="hidden" name="carritoId" value="@Model.Cabecera.CarritoId" />
                                <button type="submit" class="btn-tienda d-block w-100 text-center border-0"
                                        onclick="return confirm('¿Confirmar el pedido?')" style="cursor: pointer;">
                                    <i class="bi bi-check-circle me-2"></i>Confirmar Orden
                                </button>
                            </form>
                        }

                        <a asp-controller="Carrito" asp-action="Index" class="btn btn-outline-secondary d-block mt-3 w-100" style="border-radius: 30px;">
                            <i class="bi bi-arrow-left me-1"></i>Volver al carrito
                        </a>

                        <div class="text-center mt-3">
                            <small class="text-muted">
                                <i class="bi bi-shield-check me-1"></i>Pago 100% seguro
                            </small>
                        </div>
                    </div>
                </div>
            </div>
        }
    </div>
</section>

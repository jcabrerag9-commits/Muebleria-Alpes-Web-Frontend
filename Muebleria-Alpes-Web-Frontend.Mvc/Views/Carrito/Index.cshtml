@using Muebleria_Alpes_Web_Frontend.Mvc.ViewModels
@model CarritoViewModel
@{
    Layout = "_LayoutTienda";
    ViewData["Title"] = "Mi Carrito";

    bool tieneItems = Model.Detalle.Any();
    decimal subtotal = Model.Cabecera?.Subtotal ?? Model.Detalle.Sum(d => d.Subtotal);
    decimal impuestos = Math.Round(subtotal * 0.12m, 2);
    decimal total = subtotal + impuestos;
}

<!-- Breadcrumb -->
<div class="tienda-breadcrumb">
    <div class="container">
        <nav aria-label="breadcrumb">
            <ol class="breadcrumb mb-0">
                <li class="breadcrumb-item"><a asp-controller="Tienda" asp-action="Index">Inicio</a></li>
                <li class="breadcrumb-item active">Mi Carrito</li>
            </ol>
        </nav>
    </div>
</div>

<section class="py-5">
    <div class="container">
        <h2 class="section-title mb-4"><i class="bi bi-cart3 me-2"></i>Mi Carrito</h2>

        @if (TempData["Success"] != null)
        {
            <div class="alert alert-success alert-dismissible fade show" data-auto-dismiss role="alert">
                <i class="bi bi-check-circle me-2"></i>@TempData["Success"]
                <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
            </div>
        }
        @if (TempData["Error"] != null)
        {
            <div class="alert alert-danger alert-dismissible fade show" data-auto-dismiss role="alert">
                <i class="bi bi-exclamation-triangle me-2"></i>@TempData["Error"]
                <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
            </div>
        }

        @if (!tieneItems)
        {
            <div class="empty-state">
                <i class="bi bi-cart-x d-block"></i>
                <p class="mt-3 fw-semibold">Tu carrito está vacío.</p>
                <p class="text-muted small">Agrega productos desde el catálogo para comenzar a comprar.</p>
                <a asp-controller="Tienda" asp-action="Catalogo" class="btn-tienda mt-3">
                    <i class="bi bi-grid me-1"></i>Ir al catálogo
                </a>
            </div>
        }
        else
        {
            <div class="row g-4">
                <!-- Cart Items -->
                <div class="col-lg-8">
                    <div class="card border-0 shadow-sm" style="border-radius: 14px;">
                        <div class="card-body p-4">
                            @foreach (var item in Model.Detalle)
                            {
                                <div class="carrito-item">
                                    <div class="d-flex align-items-center gap-3">
                                        <div class="rounded-3 d-flex align-items-center justify-content-center"
                                             style="width: 70px; height: 70px; background: var(--tienda-light); flex-shrink: 0;">
                                            <i class="bi bi-image text-muted fs-3"></i>
                                        </div>
                                        <div class="flex-grow-1">
                                            <h6 class="mb-1 fw-bold">@item.ProductoNombre</h6>
                                            <div class="text-muted small">
                                                Precio unitario: <strong>Q @item.PrecioUnitario.ToString("N2")</strong>
                                            </div>
                                            <div class="text-muted small">
                                                Cantidad: <strong>@item.Cantidad</strong>
                                            </div>
                                        </div>
                                        <div class="text-end">
                                            <div class="fw-bold" style="color: var(--tienda-primary); font-size: 1.1rem;">
                                                Q @item.Subtotal.ToString("N2")
                                            </div>
                                            <form asp-action="Eliminar" method="post" class="mt-1">
                                                @Html.AntiForgeryToken()
                                                <input type="hidden" name="detalleId" value="@item.DetalleId" />
                                                <button type="submit" class="btn btn-sm btn-outline-danger" style="border-radius: 8px;"
                                                        onclick="return confirm('¿Eliminar este producto del carrito?')">
                                                    <i class="bi bi-trash"></i>
                                                </button>
                                            </form>
                                        </div>
                                    </div>
                                </div>
                            }

                            <!-- Vaciar carrito -->
                            <div class="d-flex justify-content-between align-items-center pt-3">
                                <a asp-controller="Tienda" asp-action="Catalogo" class="text-muted text-decoration-none small">
                                    <i class="bi bi-arrow-left me-1"></i>Seguir comprando
                                </a>
                                @if (Model.Cabecera != null)
                                {
                                    <form asp-action="Vaciar" method="post">
                                        @Html.AntiForgeryToken()
                                        <input type="hidden" name="carritoId" value="@Model.Cabecera.CarritoId" />
                                        <button type="submit" class="btn btn-sm btn-outline-secondary" style="border-radius: 8px;"
                                                onclick="return confirm('¿Vaciar todo el carrito?')">
                                            <i class="bi bi-trash3 me-1"></i>Vaciar carrito
                                        </button>
                                    </form>
                                }
                            </div>
                        </div>
                    </div>
                </div>

                <!-- Order Summary -->
                <div class="col-lg-4">
                    <div class="carrito-resumen">
                        <h5 class="fw-bold mb-4" style="color: var(--tienda-primary);">Resumen del pedido</h5>
                        <div class="d-flex justify-content-between mb-2">
                            <span class="text-muted">Subtotal</span>
                            <span>Q @subtotal.ToString("N2")</span>
                        </div>
                        <div class="d-flex justify-content-between mb-3">
                            <span class="text-muted">IVA (12%)</span>
                            <span>Q @impuestos.ToString("N2")</span>
                        </div>
                        <hr />
                        <div class="d-flex justify-content-between mb-4">
                            <span class="fw-bold">Total</span>
                            <span class="carrito-total">Q @total.ToString("N2")</span>
                        </div>
                        <a asp-controller="Carrito" asp-action="Checkout" class="btn-tienda d-block text-center">
                            <i class="bi bi-lock me-2"></i>Proceder al pago
                        </a>
                        <div class="text-center mt-3">
                            <small class="text-muted">
                                <i class="bi bi-shield-check me-1"></i>Pago 100% seguro
                            </small>
                        </div>
                    </div>
                </div>
            </div>
        }
    </div>
</section>

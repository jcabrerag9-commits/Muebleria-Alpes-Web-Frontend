@using Muebleria_Alpes_Web_Frontend.Mvc.ViewModels.RecursosHumanos
@model List<VacacionViewModel>

@{
    ViewData["Title"] = "Vacaciones";
}

<div class="page-header">
    <div class="page-title-box">
        <div class="page-icon">
            <i class="bi bi-umbrella"></i>
        </div>
        <div>
            <h1>Vacaciones</h1>
            <p>Gestión de solicitudes de vacaciones</p>
        </div>
    </div>

    <div class="page-actions">
        <button class="btn btn-primary btn-main" data-bs-toggle="modal" data-bs-target="#modalSolicitarVacacion">
            <i class="bi bi-plus-lg"></i> Nueva Solicitud
        </button>
    </div>
</div>

@if (TempData["Success"] != null)
{
    <div class="alert alert-success">@TempData["Success"]</div>
}

@if (TempData["Error"] != null)
{
    <div class="alert alert-danger">@TempData["Error"]</div>
}

<div class="erp-card mb-3">
    <form asp-controller="Vacaciones" asp-action="Index" method="get" class="row g-2 align-items-end p-3">
        <div class="col-md-4">
            <label class="form-label">Empleado ID</label>
            <input type="number" name="empleadoId" class="form-control" value="@ViewBag.EmpleadoId" placeholder="ID del empleado" />
        </div>
        <div class="col-md-4">
            <label class="form-label">Estado</label>
            <select name="estado" class="form-select">
                <option value="">Todos</option>
                <option value="PENDIENTE" selected="@(ViewBag.Estado == "PENDIENTE")">PENDIENTE</option>
                <option value="APROBADO" selected="@(ViewBag.Estado == "APROBADO")">APROBADO</option>
                <option value="RECHAZADO" selected="@(ViewBag.Estado == "RECHAZADO")">RECHAZADO</option>
                <option value="CANCELADO" selected="@(ViewBag.Estado == "CANCELADO")">CANCELADO</option>
            </select>
        </div>
        <div class="col-md-4">
            <button type="submit" class="btn btn-primary w-100 btn-main">
                <i class="bi bi-search"></i> Filtrar
            </button>
        </div>
    </form>
</div>

<div class="record-count">
    @Model.Count registros
</div>

<div class="erp-card">
    <div class="table-responsive">
        <table class="table erp-table">
            <thead>
                <tr>
                    <th>Empleado</th>
                    <th>Fecha Inicio</th>
                    <th>Fecha Fin</th>
                    <th>Días</th>
                    <th>Estado</th>
                    <th class="text-end">Acciones</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var v in Model)
                {
                    <tr>
                        <td>
                            <div class="employee-cell">
                                <div class="employee-avatar">@v.EmpleadoId</div>
                                <div class="employee-name">Empleado #@v.EmpleadoId</div>
                            </div>
                        </td>
                        <td>@v.FechaInicio.ToString("dd/MM/yyyy")</td>
                        <td>@v.FechaFin.ToString("dd/MM/yyyy")</td>
                        <td>@v.DiasSolicitados</td>
                        <td>
                            @{
                                var badgeClass = v.Estado switch
                                {
                                    "PENDIENTE" => "status-badge status-warning",
                                    "APROBADO" => "status-badge status-active",
                                    "RECHAZADO" => "status-badge status-inactive",
                                    "CANCELADO" => "status-badge status-inactive",
                                    _ => "status-badge status-inactive"
                                };
                            }
                            <span class="@badgeClass">@v.Estado</span>
                        </td>
                        <td class="text-end">
                            <div class="action-group">
                                @if (v.Estado == "PENDIENTE")
                                {
                                    <form asp-controller="Vacaciones" asp-action="Aprobar" asp-route-id="@v.VacacionId" method="post" class="d-inline">
                                        <button type="submit" class="btn-icon btn-activate" title="Aprobar">
                                            <i class="bi bi-check-circle"></i>
                                        </button>
                                    </form>

                                    <button class="btn-icon btn-delete"
                                            type="button"
                                            data-bs-toggle="modal"
                                            data-bs-target="#modalRechazar-@v.VacacionId"
                                            title="Rechazar">
                                        <i class="bi bi-x-circle"></i>
                                    </button>
                                }
                            </div>
                        </td>
                    </tr>

                    @if (v.Estado == "PENDIENTE")
                    {
                        <div class="modal fade" id="modalRechazar-@v.VacacionId" tabindex="-1" aria-hidden="true">
                            <div class="modal-dialog">
                                <div class="modal-content">
                                    <div class="modal-header">
                                        <h5 class="modal-title">Rechazar Vacaciones</h5>
                                        <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
                                    </div>
                                    <form asp-controller="Vacaciones" asp-action="Rechazar" asp-route-id="@v.VacacionId" method="post">
                                        <div class="modal-body">
                                            <div class="mb-3">
                                                <label class="form-label">Motivo del rechazo</label>
                                                <textarea name="motivo" class="form-control" rows="3" placeholder="Ingrese el motivo del rechazo"></textarea>
                                            </div>
                                        </div>
                                        <div class="modal-footer">
                                            <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancelar</button>
                                            <button type="submit" class="btn btn-danger">
                                                <i class="bi bi-x-circle"></i> Rechazar
                                            </button>
                                        </div>
                                    </form>
                                </div>
                            </div>
                        </div>
                    }
                }
            </tbody>
        </table>
    </div>
</div>

@await Html.PartialAsync("_SolicitarVacacionModal", new CrearVacacionViewModel())
